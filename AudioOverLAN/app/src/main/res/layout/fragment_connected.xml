<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Waveform Visualizer -->
            <com.example.audiooverlan.UI.WaveformView
                android:id="@+id/waveformView"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="8dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:id="@+id/tvServerIp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/text_gray"
                            android:textSize="14sp"
                            tools:text="192.168.1.10" />

                        <TextView
                            android:id="@+id/tvAudioEngine"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:textColor="@color/primary_green"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_connect_badge"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="1dp"
                            tools:text="AAudio (Oboe)"/>

                        <View
                            android:id="@+id/viewStatusDot"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_status_dot"
                            android:backgroundTint="@color/primary_green"/>

                        <TextView
                            android:id="@+id/tvStatusText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connected"
                            android:textColor="@color/primary_green"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvConnectionTime"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/text_gray"
                            android:textSize="16sp"
                            tools:text="00:41" />

                        <Button
                            android:id="@+id/btnMute"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:text="MUTE"
                            android:textColor="@color/primary_green"
                            app:icon="@drawable/ic_volume_up"
                            app:iconTint="@color/primary_green"
                            app:strokeColor="@color/primary_green"
                            app:strokeWidth="1dp"/>

                        <Button
                            android:id="@+id/btnStop"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:backgroundTint="@color/primary_green_dark"
                            android:text="STOP"
                            android:textColor="@color/white" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stats Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BUFFER"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp"
                            android:drawablePadding="4dp"
                            app:drawableStartCompat="@drawable/ic_computer"
                            app:drawableTint="@color/text_gray"/>

                        <TextView
                            android:id="@+id/tvBuffer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12sp"
                            android:text="0 ms"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/background_dark"
                        android:layout_marginHorizontal="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                         <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NETWORK"
                            android:textColor="@color/text_gray"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvNetLatency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 ms"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvLatency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Buf Avg: 0.0 ms"
                            android:textColor="@color/text_gray"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp"/>
                         <TextView
                            android:id="@+id/tvMaxLatency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Buf Max: 0 ms"
                            android:textColor="@color/text_gray"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stream Health Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STREAM HEALTH"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bitrate"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvBitrate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kbps"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Interpolated (PLC)"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvLostPackets"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 pkts"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dropped (Late)"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/tvLatePackets"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 pkts"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Audio Behavior Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAudioBehavior"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="8dp"
                app:strokeColor="@color/primary_green"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUDIO BEHAVIOR"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Exclusive Audio Mode -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Exclusive Audio"
                            android:textColor="@color/white"
                            android:textSize="14sp"/>

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleExclusive"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnExclusiveOff"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="OFF"
                                android:textSize="11sp"
                                android:minWidth="56dp"
                                android:paddingHorizontal="8dp"
                                app:strokeColor="@color/text_gray"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnExclusiveOn"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="ON"
                                android:textSize="11sp"
                                android:minWidth="56dp"
                                android:paddingHorizontal="8dp"
                                app:strokeColor="@color/text_gray"/>

                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvExclusiveDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Play along with other apps."
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:textStyle="italic"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/background_dark"
                        android:layout_marginVertical="12dp"/>

                    <!-- DRC -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Server DRC"
                            android:textColor="@color/white"
                            android:textSize="14sp"/>

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleDRC"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDrcOff"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="OFF"
                                android:textSize="11sp"
                                android:minWidth="56dp"
                                android:paddingHorizontal="8dp"
                                app:strokeColor="@color/text_gray"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnDrcOn"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="ON"
                                android:textSize="11sp"
                                android:minWidth="56dp"
                                android:paddingHorizontal="8dp"
                                app:strokeColor="@color/text_gray"/>

                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDrcDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stabilize volume on server before sending."
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:textStyle="italic"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/background_dark"
                        android:layout_marginVertical="12dp"/>

                    <!-- AAudio Low Latency -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvAAudioLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Playback Engine"
                            android:textColor="@color/white"
                            android:textSize="14sp"/>

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleAAudio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAudioTrack"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="AudioTrack"
                                android:textSize="11sp"
                                android:textAllCaps="false"
                                android:minWidth="56dp"
                                android:paddingHorizontal="8dp"
                                app:strokeColor="@color/text_gray"/>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnAAudio"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="AAudio"
                                android:textSize="11sp"
                                android:textAllCaps="false"
                                android:minWidth="56dp"
                                android:paddingHorizontal="8dp"
                                app:strokeColor="@color/text_gray"/>

                        </com.google.android.material.button.MaterialButtonToggleGroup>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAAudioDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Use native AAudio for lowest latency."
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        android:textStyle="italic"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/background_dark"
                        android:layout_marginVertical="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Equalizer Preset"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEqPreset"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/background_dark"
                        app:boxStrokeColor="@color/primary_green"
                        app:boxStrokeWidth="2dp"
                        app:hintEnabled="false">

                        <AutoCompleteTextView
                            android:id="@+id/actvEqPreset"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            tools:ignore="LabelFor" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvEqDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No adjustment (Flat)."
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        android:textStyle="italic"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Buffer Settings Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBufferSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="8dp"
                app:strokeColor="@color/primary_green"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BUFFER SETTINGS"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAdaptive"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Adaptive Buffering"
                        android:textColor="@color/white"
                        android:checked="true"
                        app:thumbTint="@color/primary_green"
                        app:trackTint="@color/text_gray" />

                    <LinearLayout
                        android:id="@+id/llFixedBuffer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fixed Buffer Size"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:layout_marginBottom="8dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilBuffer"
                            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:boxBackgroundColor="@color/background_dark"
                            app:boxStrokeColor="@color/primary_green"
                            app:boxStrokeWidth="2dp"
                            app:hintEnabled="false">

                            <AutoCompleteTextView
                                android:id="@+id/actvBufferSize"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:paddingTop="12dp"
                                android:paddingBottom="12dp"
                                tools:ignore="LabelFor" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvBufferDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Automatically adjusts for network jitter."
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        android:textStyle="italic"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Audio Settings Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAudioSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="8dp"
                app:strokeColor="@color/primary_green"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUDIO SETTINGS"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Opus Bitrate"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilBitrate"
                        style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/background_dark"
                        app:boxStrokeColor="@color/primary_green"
                        app:boxStrokeWidth="2dp"
                        app:hintEnabled="false">

                        <AutoCompleteTextView
                            android:id="@+id/actvBitrate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            tools:ignore="LabelFor" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:id="@+id/tvBitrateDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Standard quality (128 kbps)"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        android:textStyle="italic"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Dim Overlay for Focus -->
    <View
        android:id="@+id/dimOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000"
        android:visibility="gone"
        android:alpha="0"
        android:clickable="true"
        android:focusable="true" />
</LinearLayout>