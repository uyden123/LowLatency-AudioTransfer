<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Broadcasting"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvActiveSource"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_connected_pill"
        android:backgroundTint="@color/icon_bg"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="MIC SOURCE"
        android:textColor="@color/text_gray"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/tvHeader"
        app:layout_constraintEnd_toStartOf="@id/viewStatusDot"
        app:layout_constraintTop_toTopOf="@id/tvHeader" />

    <View
        android:id="@+id/viewStatusDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/bg_connected_pill"
        android:backgroundTint="@color/accent_green"
        app:layout_constraintBottom_toBottomOf="@id/tvHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvHeader" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnStopBroadcast"
        app:layout_constraintTop_toBottomOf="@id/tvHeader">

        <LinearLayout
            android:id="@+id/llMainContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Host Address Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="HOST ADDRESS"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="16dp">

                    <TextView
                        android:id="@+id/tvHostAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="192.168.1.105"
                        android:textColor="@color/white"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHostPort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignBaseline="@id/tvHostAddress"
                        android:layout_toEndOf="@id/tvHostAddress"
                        android:text=":5050"
                        android:visibility="gone"
                        android:textColor="@color/text_gray"
                        android:textSize="18sp" />

                    <ImageButton
                        android:id="@+id/btnCopyAddress"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/primary_blue_light" />

                </RelativeLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Connected Clients Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected Clients"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvActiveCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_connected_pill"
                    android:backgroundTint="@color/icon_bg"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="2 ACTIVE"
                    android:textColor="@color/text_gray"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvClients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_connected_client" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/vNoClients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_broadcast"
                        app:tint="@color/text_gray"
                        android:alpha="0.4"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Waiting for connections..."
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Stream is active but no devices connected"
                        android:textColor="@color/text_gray"
                        android:textSize="12sp"
                        android:gravity="center"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Audio Processing Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Audio Processing"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Volume Boost Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/ivBoostSub"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_connected_pill"
                            android:backgroundTint="@color/icon_bg"
                            android:padding="8dp"
                            android:layout_marginTop="8dp"
                            android:src="@drawable/ic_volume_up"
                            app:tint="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/ivBoostSub"
                            android:text="Volume Boost"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swVolumeBoost"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:thumbTint="@color/switch_thumb_selector"
                            app:trackTint="@color/switch_track_selector"/>

                    </RelativeLayout>

                    <LinearLayout
                        android:id="@+id/llBoostControls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BOOST LEVEL"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvBoostLevelValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="2.5x"
                                android:textColor="@color/primary_blue_light"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </RelativeLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderVolumeLevel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:value="2.5"
                            android:valueFrom="1.1"
                            android:valueTo="5.0"
                            android:stepSize="0.1"
                            app:thumbColor="@color/primary_blue_light"
                            app:trackColorActive="@color/primary_blue_light"
                            app:trackColorInactive="@color/divider" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.1x" android:textColor="@color/text_gray" android:textSize="10sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="5.0x" android:textColor="@color/text_gray" android:textSize="10sp"/>
                        </RelativeLayout>
                        
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Noise Suppression Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/ivNSSub"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_connected_pill"
                            android:backgroundTint="@color/icon_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_noise"
                            app:tint="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/ivNSSub"
                            android:text="Noise Suppression"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <!-- Noise Suppression Selection List -->
                    <LinearLayout
                        android:id="@+id/llNsList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp">

                        <!-- Mode: Off -->
                        <RelativeLayout
                            android:id="@+id/rowNsOff"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:background="@drawable/bg_ns_mode_unselected"
                            android:layout_marginBottom="10dp"
                            android:clickable="true"
                            android:focusable="true">
                            
                            <ImageView
                                android:id="@+id/ivNsOff"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_power"
                                app:tint="@color/text_gray"
                                android:padding="6dp"
                                android:background="@drawable/bg_connected_pill"
                                android:backgroundTint="@color/icon_bg"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_toEndOf="@id/ivNsOff"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Turn Off"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="No audio processing, lowest latency"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"/>
                            </LinearLayout>

                            <View
                                android:id="@+id/indicatorNsOff"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:background="@drawable/bg_status_dot"
                                android:backgroundTint="@color/primary_blue"
                                android:visibility="invisible"/>
                        </RelativeLayout>

                        <!-- Mode: RNNoise -->
                        <RelativeLayout
                            android:id="@+id/rowNsRNNoise"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:background="@drawable/bg_ns_mode_unselected"
                            android:layout_marginBottom="10dp"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/ivNsRNNoise"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_noise"
                                app:tint="@color/text_gray"
                                android:padding="6dp"
                                android:background="@drawable/bg_connected_pill"
                                android:backgroundTint="@color/icon_bg"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_toEndOf="@id/ivNsRNNoise"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RNNoise"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CPU-efficient noise suppression"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"/>
                            </LinearLayout>

                            <View
                                android:id="@+id/indicatorNsRNNoise"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:background="@drawable/bg_status_dot"
                                android:backgroundTint="@color/primary_blue"
                                android:visibility="invisible"/>
                        </RelativeLayout>

                        <!-- Mode: DeepFilter -->
                        <RelativeLayout
                            android:id="@+id/rowNsDeepFilter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="12dp"
                            android:background="@drawable/bg_ns_mode_unselected"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/ivNsDeepFilter"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_settings"
                                app:tint="@color/text_gray"
                                android:padding="6dp"
                                android:background="@drawable/bg_connected_pill"
                                android:backgroundTint="@color/icon_bg"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_toEndOf="@id/ivNsDeepFilter"
                                android:layout_marginStart="12dp"
                                android:layout_centerVertical="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="DeepFilterNet"
                                    android:textColor="@color/white"
                                    android:textStyle="bold"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Neural AI studio-quality filter"
                                    android:textColor="@color/text_gray"
                                    android:textSize="12sp"/>
                            </LinearLayout>

                            <View
                                android:id="@+id/indicatorNsDeepFilter"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:background="@drawable/bg_status_dot"
                                android:backgroundTint="@color/primary_blue"
                                android:visibility="invisible"/>
                        </RelativeLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/llNsStrength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SUPPRESSION STRENGTH"
                                android:textColor="@color/text_gray"
                                android:textSize="11sp"
                                android:letterSpacing="0.05" />

                            <TextView
                                android:id="@+id/tvNsStrengthValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="45dB"
                                android:textColor="@color/primary_blue_light"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </RelativeLayout>

                        <com.google.android.material.slider.Slider
                            android:id="@+id/sliderNoiseLevel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:value="45"
                            android:valueFrom="10"
                            android:valueTo="100"
                            android:stepSize="1"
                            app:thumbColor="@color/primary_blue_light"
                            app:trackColorActive="@color/primary_blue_light"
                            app:trackColorInactive="@color/divider" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10dB" android:textColor="@color/text_gray" android:textSize="10sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="100dB" android:textColor="@color/text_gray" android:textSize="10sp"/>
                        </RelativeLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>



        </LinearLayout>
    </ScrollView>

    <!-- Stop Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStopBroadcast"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="STOP BROADCAST"
        android:textColor="#3E2723"
        android:textSize="16sp"
        android:textStyle="bold"
        app:icon="@drawable/ic_stop"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconSize="20dp"
        app:iconTint="#3E2723"
        app:backgroundTint="#F8BBD0"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
