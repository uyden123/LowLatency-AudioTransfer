<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Broadcasting"
        android:textColor="@color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewStatusDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_connected_pill"
        android:backgroundTint="@color/accent_green"
        app:layout_constraintBottom_toBottomOf="@id/tvHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvHeader" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnStopBroadcast"
        app:layout_constraintTop_toBottomOf="@id/tvHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Host Address Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="HOST ADDRESS"
                android:textColor="@color/text_gray"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="16dp">

                    <TextView
                        android:id="@+id/tvHostAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:text="192.168.1.105"
                        android:textColor="@color/white"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHostPort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignBaseline="@id/tvHostAddress"
                        android:layout_toEndOf="@id/tvHostAddress"
                        android:text=":5050"
                        android:textColor="@color/text_gray"
                        android:textSize="18sp" />

                    <ImageButton
                        android:id="@+id/btnCopyAddress"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_copy"
                        app:tint="@color/primary_blue_light" />

                </RelativeLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Audio Processing Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Audio Processing"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Volume Boost Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/ivBoostSub"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_connected_pill"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="8dp"
                            android:src="@drawable/ic_volume_up"
                            app:tint="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/ivBoostSub"
                            android:text="Volume Boost"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/swVolumeBoost"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BOOST LEVEL"
                            android:textColor="@color/text_gray"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvBoostLevelValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="2.5x"
                            android:textColor="@color/primary_blue_light"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderVolumeLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:value="2.5"
                        android:valueFrom="1.1"
                        android:valueTo="5.0"
                        android:stepSize="0.1"
                        app:thumbColor="@color/primary_blue_light"
                        app:trackColorActive="@color/primary_blue_light"
                        app:trackColorInactive="#20FFFFFF" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.1x" android:textColor="@color/text_gray" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="5.0x" android:textColor="@color/text_gray" android:textSize="10sp"/>
                    </RelativeLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Noise Suppression Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/card_background"
                app:cardCornerRadius="24dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/ivNSSub"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_connected_pill"
                            android:backgroundTint="#1AFFFFFF"
                            android:padding="8dp"
                            android:src="@drawable/ic_noise"
                            app:tint="@color/white" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/ivNSSub"
                            android:text="Noise Suppression"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleNS"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:checkedButton="@+id/btnNsDeepFilter"
                        android:background="@drawable/bg_connected_pill"
                        android:backgroundTint="#0DFFFFFF">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNsOff"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="Off"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="@android:color/transparent"
                            app:rippleColor="#20FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNsRNNoise"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="RNNoise"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="@android:color/transparent"
                            app:rippleColor="#20FFFFFF" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnNsDeepFilter"
                            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1.2"
                            android:text="DeepFilterNet"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            app:backgroundTint="#2D323A"
                            app:cornerRadius="20dp" />

                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SUPPRESSION STRENGTH"
                            android:textColor="@color/text_gray"
                            android:textSize="11sp"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvNsStrengthValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="45dB"
                            android:textColor="@color/primary_blue_light"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </RelativeLayout>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderNoiseLevel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:value="45"
                        android:valueFrom="10"
                        android:valueTo="100"
                        android:stepSize="1"
                        app:thumbColor="@color/primary_blue_light"
                        app:trackColorActive="@color/primary_blue_light"
                        app:trackColorInactive="#20FFFFFF" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="10dB" android:textColor="@color/text_gray" android:textSize="10sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="100dB" android:textColor="@color/text_gray" android:textSize="10sp"/>
                    </RelativeLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Connected Clients Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected Clients"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvActiveCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_connected_pill"
                    android:backgroundTint="#0DFFFFFF"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="2 ACTIVE"
                    android:textColor="@color/text_gray"
                    android:textSize="11sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvClients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_connected_client" />
            
            <TextView
                android:id="@+id/tvNoClients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="24dp"
                android:text="No connected device yet"
                android:textColor="@color/text_gray"
                android:textSize="15sp"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- Stop Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStopBroadcast"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="STOP BROADCAST"
        android:textColor="#3E2723"
        android:textSize="16sp"
        android:textStyle="bold"
        app:icon="@drawable/ic_stop"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconSize="20dp"
        app:iconTint="#3E2723"
        app:backgroundTint="#F8BBD0"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
