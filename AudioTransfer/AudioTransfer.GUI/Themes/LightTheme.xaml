<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Light Theme Colors -->
    <Color x:Key="BgColor">#F5F5F5</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="BottomBarColor">#EEEEEE</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="AccentColor">#2E7D32</Color> <!-- Darker green for light theme -->
    <Color x:Key="AccentHoverColor">#1B5E20</Color>
    <Color x:Key="AccentPressColor">#0D3D0F</Color>
    <Color x:Key="AccentDimColor">#1A2E7D32</Color>
    <Color x:Key="AccentPressBgColor">#332E7D32</Color>
    <Color x:Key="TextPrimaryColor">#212121</Color>
    <Color x:Key="TextSecondaryColor">#757575</Color>
    <Color x:Key="DividerColor">#E0E0E0</Color>
    <Color x:Key="HoverColor">#F0F0F0</Color>
    <Color x:Key="InputBgColor">#FFFFFF</Color>
    <Color x:Key="InputBorderColor">#CCCCCC</Color>
    <Color x:Key="WarningBgColor">#FFF3E0</Color>
    <Color x:Key="WarningColor">#F57C00</Color>
    <Color x:Key="ToggleOffTrackColor">#BDBDBD</Color>
    <Color x:Key="ErrorColor">#D32F2F</Color>
    <Color x:Key="ErrorDimColor">#FFEBEE</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BottomBarBrush" Color="{StaticResource BottomBarColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="#EEEEEE"/>

    <!-- Other UI Elements -->
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#44000000"/> <!-- Semi-transparent black -->
    <SolidColorBrush x:Key="NavForegroundBrush" Color="#757575"/>
    <SolidColorBrush x:Key="NavHoverBrush" Color="#212121"/>

</ResourceDictionary>
