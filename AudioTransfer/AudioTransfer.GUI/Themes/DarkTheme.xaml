<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Colors -->
    <Color x:Key="BgColor">#1E1E1E</Color>
    <Color x:Key="SurfaceColor">#2D2D2D</Color>
    <Color x:Key="BottomBarColor">#252525</Color>
    <Color x:Key="CardColor">#2D2D2D</Color>
    <Color x:Key="AccentColor">#4CAF50</Color>
    <Color x:Key="AccentHoverColor">#43A047</Color>
    <Color x:Key="AccentPressColor">#388E3C</Color>
    <Color x:Key="AccentDimColor">#1A4CAF50</Color>
    <Color x:Key="AccentPressBgColor">#334CAF50</Color>
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#9E9E9E</Color>
    <Color x:Key="DividerColor">#383838</Color>
    <Color x:Key="HoverColor">#333333</Color>
    <Color x:Key="InputBgColor">#353535</Color>
    <Color x:Key="InputBorderColor">#444444</Color>
    <Color x:Key="WarningBgColor">#2A2520</Color>
    <Color x:Key="WarningColor">#FFB74D</Color>
    <Color x:Key="ToggleOffTrackColor">#555555</Color>
    <Color x:Key="ErrorColor">#FF5252</Color>
    <Color x:Key="ErrorDimColor">#2A2020</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BottomBarBrush" Color="{StaticResource BottomBarColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
    <SolidColorBrush x:Key="ControlBgBrush" Color="{StaticResource SurfaceColor}"/>

    <!-- Other UI Elements -->
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#44FFFFFF"/>
    <SolidColorBrush x:Key="NavForegroundBrush" Color="#9E9E9E"/>
    <SolidColorBrush x:Key="NavHoverBrush" Color="#CCCCCC"/>

</ResourceDictionary>
