<Window x:Class="AudioTransfer.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioTransfer.GUI"
        xmlns:conv="clr-namespace:AudioTransfer.GUI.Converters"
        mc:Ignorable="d"
        Title="Ethereal Audio" Height="850" Width="1150"
        MinWidth="1050" MinHeight="800"
        Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Display, Segoe UI, Inter"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" Inverse="True"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:InverseCountToVisibilityConverter x:Key="InverseCountToVisibilityConverter"/>
        
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- SCROLLBAR CUSTOMIZATION                             -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Style x:Key="EtherealScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="Rectangle1" CornerRadius="3" Background="{DynamicResource ScrollbarThumbBrush}" Opacity="0.25" Margin="2,0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Rectangle1" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource EtherealScrollBarThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="Bg" SnapsToDevicePixels="true">
                                    <Track x:Name="PART_Track" IsDirectionReversed="false" IsEnabled="{TemplateBinding IsEnabled}">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource EtherealScrollBarThumb}" Margin="0,2"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- CORE COMPONENT STYLES                               -->
        <!-- ═══════════════════════════════════════════════════ -->

        <!-- Sidebar Nav Button -->
        <Style x:Key="SidebarNavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavForegroundBrush}"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <Border x:Name="Indicator" Width="8" HorizontalAlignment="Left" 
                                    Background="{DynamicResource AccentBrush}" Opacity="0"
                                    Margin="0,8"/>
                            <ContentPresenter Margin="24,0,16,0" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource NavHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Card (The editorial look) -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainerHighestBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Signature Gradient CTA Button -->
        <Style x:Key="GradientCTAButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource GradientCTABrush}"/>
            <Setter Property="Foreground" Value="#131313"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <!-- Subtle inner glow -->
                                <Border CornerRadius="8" BorderThickness="1" BorderBrush="#33FFFFFF" Margin="0" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="100" CenterY="25"/>
                                    </Setter.Value> 
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost Button/Mode Toggle -->
        <Style x:Key="GhostToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SurfaceBrightBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EtherealComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecBrush}"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="4,2">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource SurfaceBrightBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource OutlineVariantColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dropdown / ComboBox -->
        <Style x:Key="EtherealComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowestBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource EtherealComboBoxItem}"/>
            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ComboBox_PreviewMouseDown"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" 
                                    Padding="{TemplateBinding Padding}" Cursor="Hand" SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" 
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      VerticalAlignment="Center"/>
                                    <Path Grid.Column="1" Data="M0,0 L4,4 L8,0" Stroke="{DynamicResource TextSecBrush}" 
                                          StrokeThickness="1.5" Margin="8,4,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                                   Placement="Bottom" PopupAnimation="Fade">
                                <Border Background="{DynamicResource SurfaceContainerHighestBrush}" 
                                        BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1" CornerRadius="8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" Margin="0,4,0,0">
                                    <ScrollViewer Margin="0,4" MaxHeight="250">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceBrightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tonal Toggle Switch -->
        <Style x:Key="EtherealToggle" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Cursor="Hand">
                            <Border x:Name="Track" Width="42" Height="22" Background="{DynamicResource ToggleOffTrackColor}" CornerRadius="11"/>
                            <Border x:Name="Thumb" Width="16" Height="16" Background="White" CornerRadius="8" HorizontalAlignment="Left" Margin="3,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbPos" X="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbPos" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbPos" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sunken Text Input -->
        <Style x:Key="EtherealTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainerLowestBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8"/>
                            <Border x:Name="Glow" BorderThickness="0,0,0,2" BorderBrush="{DynamicResource AccentBrush}" 
                                    CornerRadius="0,0,8,8" Opacity="0" VerticalAlignment="Bottom"/>
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                            <TextBlock IsHitTestVisible="False" Text="{TemplateBinding Tag}" Margin="{TemplateBinding Padding}" 
                                       Foreground="{DynamicResource TextSecBrush}" Opacity="0.4" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Glow" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorialHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style x:Key="SectionSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecBrush}"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>

        <Storyboard x:Key="ShowToast">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToastBorder" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimation Storyboard.TargetName="ToastBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="ToastTransform" Storyboard.TargetProperty="X" From="400" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="HideToast">
            <DoubleAnimation Storyboard.TargetName="ToastBorder" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetName="ToastTransform" Storyboard.TargetProperty="X" To="400" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseIn" Amplitude="0.5"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToastBorder" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0:0:0.3" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="ToastTimerAnim">
            <DoubleAnimation Storyboard.TargetName="ToastTimer" Storyboard.TargetProperty="Width" From="340" To="0" Duration="0:0:4"/>
        </Storyboard>

        <Storyboard x:Key="TabFadeIn">
            <DoubleAnimation Storyboard.TargetName="MainTabs" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
            <DoubleAnimation Storyboard.TargetName="MainTabsTransform" Storyboard.TargetProperty="Y" From="20" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- LEFT SIDEBAR                                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.RowSpan="3" Background="{DynamicResource SurfaceContainerLowestBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="24,60,24,60">
                    <TextBlock Text="Ethereal Audio" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="AUDIO ENGINE ACTIVE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" Opacity="0.8" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Nav Menu -->
                <StackPanel Grid.Row="1">
                    <RadioButton Name="NavServer" IsChecked="True" Style="{StaticResource SidebarNavButtonStyle}" Checked="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource IconServer}" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Server" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Name="NavPlayer" Style="{StaticResource SidebarNavButtonStyle}" Checked="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource IconPlayer}" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Player" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Name="NavSettings" Style="{StaticResource SidebarNavButtonStyle}" Checked="Nav_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource IconSettings}" FontFamily="Segoe MDL2 Assets" FontSize="16" Margin="0,0,16,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
                
                <!-- Bottom Decoration -->
                <Border Grid.Row="2" Margin="24,0,24,32" Opacity="0.1">
                    <Path Data="M0,0 L40,0" Stroke="White" StrokeThickness="1"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TOP APP BAR                                         -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Grid.Row="0" Margin="40,32,40,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Ethereal Audio" FontSize="18" FontWeight="Bold" Foreground="White" Opacity="0.9"/>
                <TextBlock Text="|" FontSize="18" Foreground="{DynamicResource TextSecBrush}" Margin="12,0" Opacity="0.3"/>
                <TextBlock x:Name="TxtActivePage" Text="SERVER CONSOLE" FontSize="18" Foreground="{DynamicResource TextSecBrush}" Opacity="0.6"/>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,10,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource ToggleOffTrackColor}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewModel.IsServerRunning}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessColor}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="OFFLINE"/>
                                <Setter Property="Opacity" Value="0.4"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViewModel.IsServerRunning}" Value="True">
                                        <Setter Property="Text" Value="LIVE"/>
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MAIN CONTENT                                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <TabControl Grid.Column="1" Grid.Row="1" x:Name="MainTabs" Background="Transparent" BorderThickness="0">
            <TabControl.RenderTransform>
                <TranslateTransform x:Name="MainTabsTransform"/>
            </TabControl.RenderTransform>
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent"/>
                </ControlTemplate>
            </TabControl.Template>

            <!-- TAB 1: SERVER -->
            <TabItem>
                <Grid Margin="40,40,40,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Hero Info -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Style="{StaticResource ModernCard}" Background="{DynamicResource SurfaceContainerHighestBrush}" ClipToBounds="True">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="HOST IDENTITY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" Margin="0,0,0,16"/>
                                    <Viewbox StretchDirection="DownOnly" Stretch="Uniform" HorizontalAlignment="Left" MaxHeight="64">
                                        <TextBlock Text="{Binding ViewModel.HostName}" FontSize="48" FontWeight="Bold" Foreground="White"/>
                                    </Viewbox>
                                    <Border Background="{DynamicResource SurfaceBrightBrush}" CornerRadius="12" Padding="12,4" HorizontalAlignment="Left" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ViewModel.LocalIps}" FontSize="12" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource ModernCard}">
                            <StackPanel>
                                <TextBlock Text="STREAMING HEALTH" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" Margin="0,0,0,12"/>
                                
                                <Grid Margin="0,4,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Engine Load" FontSize="10" Foreground="{DynamicResource TextSecBrush}" Opacity="0.7"/>
                                        <ProgressBar Value="{Binding ViewModel.ServerCpuLoad}" Height="6" Margin="0,8,0,0" 
                                                     Background="{DynamicResource SurfaceContainerHighBrush}" Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding ViewModel.ServerCpuLoadText}" FontSize="28" 
                                               Foreground="White" Margin="20,0,0,0" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{DynamicResource OutlineVariantColor}" CornerRadius="8" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="BANDWIDTH" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ViewModel.ServerBandwidth}" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="{DynamicResource OutlineVariantColor}" CornerRadius="8" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="TOTAL DATA" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ViewModel.ServerTotalData}" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Routing & Connected Row -->
                    <Grid Grid.Row="1" Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <!-- Audio Routing -->
                        <Border Grid.Column="0" Style="{StaticResource ModernCard}" Padding="32,24">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource AccentBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Audio Routing" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextSecBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <TextBlock Text="SELECT AUDIO SOURCE DEVICE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" Margin="4,0,0,8"/>
                                <ComboBox ItemsSource="{Binding ViewModel.CaptureDevices}" 
                                          SelectedItem="{Binding ViewModel.SelectedCaptureDevice}"
                                          Style="{StaticResource EtherealComboBox}"/>

                                <Grid Margin="0,24,0,0">
                                    <Border Grid.Column="2" Background="{DynamicResource OutlineVariantColor}" CornerRadius="8" Padding="12">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Mute audio on this PC when streaming" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecBrush}"/>
                                            <TextBlock Text="Prevents echo by silencing local playback" FontSize="12" Foreground="{DynamicResource TextSecBrush}"/>
                                        </StackPanel>
                                     </Border>
                                     <CheckBox IsChecked="{Binding ViewModel.AutoMute}" Style="{StaticResource EtherealToggle}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
                                 </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Connected List -->
                        <Border Grid.Column="2" Style="{StaticResource ModernCard}" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <Grid Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource SecondaryColor}" Margin="0,0,10,0"/>
                                        <TextBlock Text="Connected" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextSecBrush}"/>
                                    </StackPanel>
                                    <Border Background="{DynamicResource SurfaceBrightBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ViewModel.ConnectedClients.Count}" FontSize="10" FontWeight="Bold" Foreground="White" Opacity="0.8"/>
                                            <TextBlock Text=" ACTIVE" FontSize="10" FontWeight="Bold" Foreground="White" Opacity="0.8" xml:space="preserve"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <!-- Placeholder for empty list -->
                                    <TextBlock Text="{Binding ViewModel.ClientListPlaceholder}" 
                                               FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" Opacity="0.4" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ViewModel.ConnectedClients.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl ItemsSource="{Binding ViewModel.ConnectedClients}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource OutlineVariantColor}" CornerRadius="8" Padding="12,10" Margin="0,0,0,8" BorderThickness="2,0,0,0" BorderBrush="{DynamicResource AccentBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DeviceType}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecBrush}"/>
                                                        <TextBlock Text="{Binding IpAddress}" FontSize="11" Foreground="{DynamicResource TextSecBrush}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Start Server Button Removed (Always On) -->
                    <Grid Grid.Row="3" Height="48"/> 
                </Grid>
            </TabItem>

            <!-- TAB 2: PLAYER -->
            <TabItem>
                <Grid x:Name="PlayerTabRoot" Margin="40,40,40,40">
                    <Grid.Resources>
                        <Storyboard x:Key="TransitionToStats">
                            <DoubleAnimation Storyboard.TargetName="ManualConnectView" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                            <DoubleAnimation Storyboard.TargetName="ManualConnectViewTransform" Storyboard.TargetProperty="Y" To="-50" Duration="0:0:0.3"/>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ManualConnectView" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0.3" Value="{x:Static Visibility.Collapsed}"/>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                        <Storyboard x:Key="TransitionToConnect">
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ManualConnectView" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                            </ObjectAnimationUsingKeyFrames>
                            <DoubleAnimation Storyboard.TargetName="ManualConnectView" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                            <DoubleAnimation Storyboard.TargetName="ManualConnectViewTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.3"/>
                        </Storyboard>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <!-- Manual Connection -->
                        <Border x:Name="ManualConnectView" Style="{StaticResource ModernCard}" Margin="0,0,0,24">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ManualConnectViewTransform"/>
                            </Border.RenderTransform>
                            <StackPanel>
                                <TextBlock Text="MANUAL CONNECTION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" Margin="0,0,0,16"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Tag="Enter IP Address (e.g. 192.168.1.104)" Style="{StaticResource EtherealTextBox}" 
                                             Text="{Binding ViewModel.TargetIp, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="2" Style="{StaticResource GradientCTAButton}" Width="160"
                                            Command="{Binding ViewModel.ToggleConnectPlayerCommand}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚡ " FontSize="16" VerticalAlignment="Center"/>
                                            <TextBlock Text="CONNECT" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                        

                        <!-- Stats View (appears when connected) -->
                        <Border x:Name="StatsView" Style="{StaticResource ModernCard}" Margin="0,0,0,24" 
                                Visibility="{Binding ViewModel.IsStatsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <Grid Margin="0,0,0,20">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessColor}" Margin="0,0,10,0"/>
                                        <TextBlock Text="ACTIVE SESSION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding ViewModel.ConnectTime}" FontSize="12" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
                                </Grid>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Background="{DynamicResource OutlineVariantColor}" CornerRadius="8" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="BUFFER" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ViewModel.BufferDelay}" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Grid.Column="2" Background="{DynamicResource OutlineVariantColor}" CornerRadius="8" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="LATENCY" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ViewModel.AverageLatency}" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <Border Grid.Column="4" Background="{DynamicResource OutlineVariantColor}" CornerRadius="8" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="LOSS" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ViewModel.MaxLatency}" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                
                                <Button Content="DISCONNECT SESSION" Style="{StaticResource GhostButtonStyle}" 
                                        BorderThickness="1" Margin="0,20,0,0" Height="40"
                                        Command="{Binding ViewModel.ToggleConnectPlayerCommand}"/>
                            </StackPanel>
                        </Border>

                        <!-- Persistence Engine (Inside discovery section to hide together) -->
                        <Border Style="{StaticResource ModernCard}" Margin="0,0,0,20" Padding="16,14" Visibility="{Binding ViewModel.IsStatsVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="32" Height="32" Background="{DynamicResource OutlineVariantColor}" CornerRadius="16" Margin="0,0,16,0">
                                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Persistence Engine" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecBrush}"/>
                                        <TextBlock Text="Automatically connect to last used IP" FontSize="11" Foreground="{DynamicResource TextSecBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding ViewModel.AutoConnect}" Style="{StaticResource EtherealToggle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Discovery Section (Hidden when connected) -->
                        <StackPanel Visibility="{Binding ViewModel.IsStatsVisible, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <!-- Discovery List -->
                            <Grid Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE902;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource AccentBrush}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="NEARBY SERVERS" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecBrush}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="SEARCHING..." FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" 
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           Visibility="{Binding ViewModel.IsSearchingServers, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <Button Command="{Binding ViewModel.RefreshServersCommand}" Style="{StaticResource GhostButtonStyle}" Padding="8,4" Height="28">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="REFRESH" FontSize="11" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            </Grid>

                            <!-- Discovery Cards Grid -->
                            <ItemsControl ItemsSource="{Binding ViewModel.DiscoveredServers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.ViewModel.ConnectToServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="4" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Card" Style="{StaticResource ModernCard}" Margin="0" Padding="20">
                                                        <Grid>
                                                            <Border Width="40" Height="40" Background="{DynamicResource OutlineVariantColor}" CornerRadius="8" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.8"/>
                                                            </Border>
                                                            <TextBlock Text="2ms" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.5"/>
                                                            <StackPanel Margin="0,56,0,0">
                                                                <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding IpAddress}" FontSize="13" Foreground="{DynamicResource TextSecBrush}" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Card" Property="Background" Value="{DynamicResource SurfaceBrightBrush}"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Card" Property="Opacity" Value="0.8"/>
                                                            <Setter TargetName="Card" Property="RenderTransform">
                                                                <Setter.Value>
                                                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="100" CenterY="50"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>

                    <!-- Playback Controls -->
                    <StackPanel Grid.Column="2">
                        <Border Style="{StaticResource ModernCard}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                    <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource SecondaryColor}" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="MODE SELECTION" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecBrush}"/>
                                </StackPanel>

                                <UniformGrid Columns="2" Margin="0,0,0,20">
                                    <RadioButton Content="MIC Mode" Style="{StaticResource GhostToggleButtonStyle}" IsChecked="True" BorderThickness="1,1,0,1"/>
                                    <RadioButton Content="PLAYBACK" Style="{StaticResource GhostToggleButtonStyle}" BorderThickness="0,1,1,1"/>
                                </UniformGrid>

                                <Border Background="#1AFFFFFF" CornerRadius="8" Padding="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource AccentBrush}" Margin="0,4,12,0" VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="ROUTING HINT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6"/>
                                            <TextBlock Text="Audio is currently being routed to CABLE Input. Ensure your DAW or communication app is listening on this virtual bridge." 
                                                       FontSize="11" Foreground="{DynamicResource TextSecBrush}" TextWrapping="Wrap" Opacity="0.9"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <TextBlock Text="LOCAL OUTPUT DEVICE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" Margin="4,24,0,8"/>
                                <ComboBox ItemsSource="{Binding ViewModel.OutputDevices}" 
                                          SelectedItem="{Binding ViewModel.SelectedOutputDevice}" 
                                          Style="{StaticResource EtherealComboBox}"/>

                                <Grid Margin="0,32,0,0">
                                    <TextBlock Text="LATENCY OPTIMIZATION" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextSecBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="ULTRA-LOW" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource SecondaryColor}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Rectangle Height="4" Margin="0,8,0,0" RadiusX="2" RadiusY="2">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#A3C9FF" Offset="0"/>
                                            <GradientStop Color="#CFBDFF" Offset="0.8"/>
                                            <GradientStop Color="#2A2A2A" Offset="0.8"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- TAB 3: SETTINGS -->
            <TabItem>
                <ScrollViewer Margin="40" Padding="0,0,32,0">
                    <StackPanel MaxWidth="700" Width="700" HorizontalAlignment="Left" >
                        <TextBlock Text="SETTINGS" Style="{StaticResource EditorialHeader}" Foreground="{DynamicResource TextSecBrush}" />
                        <TextBlock Text="Core application parameters and behavioral configuration." Style="{StaticResource SectionSubtitle}" Margin="0,8,0,40"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0" Style="{StaticResource ModernCard}">
                                <StackPanel>
                                    <TextBlock Text="DEVICE CONFIGURATION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,16"/>
                                    <TextBlock Text="Machine Network Identifier" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{DynamicResource TextSecBrush}"/>
                                    <TextBox Text="{Binding ViewModel.DeviceName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EtherealTextBox}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource ModernCard}">
                                <StackPanel>
                                    <TextBlock Text="LOCALIZATION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,16"/>
                                    <TextBlock Text="System Language" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="{DynamicResource TextSecBrush}"/>
                                    <ComboBox SelectedItem="{Binding ViewModel.Language}" Style="{StaticResource EtherealComboBox}">
                                        <ComboBoxItem Content="English (US) - Default"/>
                                        <ComboBoxItem Content="Vietnamese"/>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource ModernCard}" Padding="20">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Dark Theme" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecBrush}"/>
                                        <TextBlock Text="Enabled globally" FontSize="11" Foreground="{DynamicResource TextSecBrush}"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding ViewModel.IsDarkTheme}" Style="{StaticResource EtherealToggle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource ModernCard}" Padding="20">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Minimize to Tray" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecBrush}"/>
                                        <TextBlock Text="Keep process alive" FontSize="11" Foreground="{DynamicResource TextSecBrush}"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding ViewModel.MinimizeToTray}" Style="{StaticResource EtherealToggle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <Border Grid.Column="4" Style="{StaticResource ModernCard}" Padding="20">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Launch on Startup" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextSecBrush}"/>
                                        <TextBlock Text="Boot with system" FontSize="11" Foreground="{DynamicResource TextSecBrush}"/>
                                    </StackPanel>
                                    <CheckBox IsChecked="{Binding ViewModel.LaunchOnStartup}" Style="{StaticResource EtherealToggle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- System Logs Section -->
                        <TextBlock Text="System Logs" FontSize="24" FontWeight="SemiBold" Margin="0,48,0,20" Foreground="{DynamicResource TextPrimaryBrush}"/>

                        <!-- Integrated Log Viewer -->
                        <Border Background="{DynamicResource SurfaceContainerLowestBrush}" CornerRadius="12" Padding="2" BorderThickness="1" BorderBrush="#1AFFFFFF">
                            <StackPanel Height="360">
                                <!-- Log Header -->
                                <Border Background="#1AFFFFFF" Padding="20,12">
                                    <Grid>
                                        <TextBlock Text="LIVE TELEMETRY STREAM" FontWeight="Bold" VerticalAlignment="Center" Foreground="White" FontSize="11"/>
                                        
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding ViewModel.ClearLogsCommand}" Style="{StaticResource GhostButtonStyle}" ToolTip="Clear Console" Margin="4,0">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.5"/>
                                            </Button>
                                            <Button Command="{Binding ViewModel.TogglePauseLogsCommand}" Style="{StaticResource GhostButtonStyle}" ToolTip="Pause/Resume" Margin="4,0">
                                                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="&#xE769;"/> <!-- Pause icon -->
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ViewModel.IsLogsPaused}" Value="True">
                                                                    <Setter Property="Text" Value="&#xE768;"/> <!-- Play icon -->
                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                            <Button Command="{Binding ViewModel.RefreshLogsCommand}" Style="{StaticResource GhostButtonStyle}" ToolTip="Reload Buffer" Margin="4,0">
                                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.5"/>
                                            </Button>
                                            <Button Command="{Binding ViewModel.ExportLogsCommand}" Style="{StaticResource GhostButtonStyle}" ToolTip="Export to File" Margin="4,0">
                                                <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="12" Opacity="0.5"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                 <!-- Real-time System Logs -->
                                <ItemsControl ItemsSource="{Binding ViewModel.SystemLogs}" Height="300"
                                              VirtualizingPanel.IsVirtualizing="True" 
                                              VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ItemsControl.Template>
                                        <ControlTemplate>
                                            <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                                                <ItemsPresenter />
                                            </ScrollViewer>
                                        </ControlTemplate>
                                    </ItemsControl.Template>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="{Binding Time}" FontFamily="Consolas" FontSize="11" Foreground="{Binding Color}" Opacity="0.4"/>
                                                <TextBlock Text="{Binding Level}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Margin="0,0,8,0" Foreground="{Binding Color}"/>
                                                <TextBlock Text="{Binding Message}" FontFamily="Consolas" FontSize="11" Foreground="{Binding Color}" Opacity="0.9" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- BOTTOM STATUS BAR                                   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#0A0A0A" BorderThickness="0,1,0,0" BorderBrush="#1AFFFFFF">
            <Grid Margin="12,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessColor}" Margin="0,0,10,0"/>
                    <TextBlock Text="ENGINE ONLINE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource NavForegroundBrush}" Opacity="0.5"/>
                    <TextBlock Text="SYSTEM HEALTH" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource NavForegroundBrush}" Margin="24,0,0,0" Opacity="0.5"/>
                    <TextBlock Text="LOGS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" Margin="24,0,0,0"/>
                    <TextBlock Text="DIAGNOSTICS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource NavForegroundBrush}" Margin="24,0,0,0" Opacity="0.5"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource NavForegroundBrush}" Opacity="0.5">
                        <Run Text="CPU: "/><Run Foreground="{DynamicResource AccentBrush}" Text="12%"/><Run Text=" | NET: "/><Run Foreground="{DynamicResource AccentBrush}" Text="45MBPS"/>
                    </TextBlock>
                    <TextBlock Text="BUILD: 2.0.4-LATEST" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource NavForegroundBrush}" Margin="24,0,0,0" Opacity="0.5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Notification Toast (Updated style) -->
        <Grid Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,20,20,0" >
            <Border x:Name="ToastBorder" Background="{DynamicResource SurfaceContainerHighestBrush}" CornerRadius="12" BorderThickness="1" BorderBrush="#1AFFFFFF"
                    Visibility="Collapsed" Opacity="0" IsHitTestVisible="True" Width="340">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTransform" X="400"/>
                </Border.RenderTransform>
                <Border Padding="20">
                    <Grid>
                        <StackPanel>
                            <TextBlock x:Name="TxtToastTitle" Text="NOTIFICATION" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontSize="14" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtToastMessage" Text="Message here" Foreground="White" FontSize="13" TextWrapping="Wrap" Opacity="0.9"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" BorderThickness="0" Click="BtnCloseToast_Click" Cursor="Hand">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="White" Opacity="0.3"/>
                        </Button>
                        <Rectangle x:Name="ToastTimer" Height="2" Fill="{DynamicResource GradientCTABrush}" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="-20,0,-20,-20"/>
                    </Grid>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
