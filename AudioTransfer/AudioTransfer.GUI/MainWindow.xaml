<Window x:Class="AudioTransfer.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioTransfer.GUI"
        xmlns:conv="clr-namespace:AudioTransfer.GUI.Converters"
        mc:Ignorable="d"
        Title="AudioTransfer" Height="800" Width="1050"
        MinWidth="850" MinHeight="800"
        Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <conv:InverseCountToVisibilityConverter x:Key="InverseCountToVisibilityConverter"/>
        <!-- ==============================================- -->
        <!-- BOTTOM NAV BUTTON (horizontal, icon + label)   -->
        <!-- ==============================================- -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource NavForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="0,8,0,6">
                                <!-- Top accent indicator -->
                                <Border x:Name="Indicator" Height="3" Width="0"
                                        HorizontalAlignment="Center" Margin="0,0,0,6"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="0,0,2,2"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Indicator" 
                                                             Storyboard.TargetProperty="Width" To="32" Duration="0:0:0.25">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Indicator" 
                                                             Storyboard.TargetProperty="Width" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="{DynamicResource NavHoverBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- MODERN CARD                                    -->
        <!-- ==============================================- -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Direction="-90" RenderingBias="Quality"
                                      ShadowDepth="4" Opacity="0.15" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- DEVICE PICKER ANIMATIONS                       -->
        <!-- ==============================================- -->
        <Storyboard x:Key="ShowDevicePicker">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DevicePickerView" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimation Storyboard.TargetName="DevicePickerTransform" 
                             Storyboard.TargetProperty="X" From="400" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DevicePickerView" 
                             Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="ServerMainViewTransform" 
                             Storyboard.TargetProperty="X" To="-400" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ServerMainView" 
                             Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
        </Storyboard>

        <Storyboard x:Key="HideDevicePicker">
            <DoubleAnimation Storyboard.TargetName="DevicePickerTransform" 
                             Storyboard.TargetProperty="X" To="400" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DevicePickerView" 
                             Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="DevicePickerView" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0:0:0.3" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimation Storyboard.TargetName="ServerMainViewTransform" 
                             Storyboard.TargetProperty="X" From="-400" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ServerMainView" 
                             Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>

        <Storyboard x:Key="ShowOutputDevicePicker">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OutputDevicePickerView" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimation Storyboard.TargetName="OutputDevicePickerTransform" 
                             Storyboard.TargetProperty="X" From="400" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="OutputDevicePickerView" 
                             Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="PlayerMainViewTransform" 
                             Storyboard.TargetProperty="X" To="-400" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PlayerMainView" 
                             Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
        </Storyboard>

        <Storyboard x:Key="HideOutputDevicePicker">
            <DoubleAnimation Storyboard.TargetName="OutputDevicePickerTransform" 
                             Storyboard.TargetProperty="X" To="400" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="OutputDevicePickerView" 
                             Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="OutputDevicePickerView" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0:0:0.3" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimation Storyboard.TargetName="PlayerMainViewTransform" 
                             Storyboard.TargetProperty="X" From="-400" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PlayerMainView" 
                             Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>

        <!-- ==============================================- -->
        <!-- PRIMARY BUTTON (outlined accent)               -->
        <!-- ==============================================- -->
        <Style x:Key="DeviceChoiceButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                Cursor="Hand">
                            <Grid Background="Transparent" >
                                <TextBlock x:Name="TxtContent"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}" 
                                           FontSize="13"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center" 
                                           Margin="0,0,30,0"/>
                                <Path Data="M0,0 L5,5 L0,10" 
                                      Stroke="{DynamicResource AccentBrush}" 
                                      StrokeThickness="2" 
                                      Width="8" Height="12" 
                                      Stretch="Uniform" 
                                      HorizontalAlignment="Right" 
                                      VerticalAlignment="Center"
                                      Margin="0,0,4,0" 
                                      StrokeStartLineCap="Round" 
                                      StrokeEndLineCap="Round" 
                                      StrokeLineJoin="Round"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#444444"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#555555"/>
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource AccentDimColor}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource AccentPressBgColor}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="#1AFFFFFF" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="Transparent" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Server Items in Discovery List -->
        <Style x:Key="ServerItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="#3D3D3D" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="{StaticResource SurfaceColor}" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- CUSTOM SCROLLBAR                               -->
        <!-- ==============================================- -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource ScrollbarThumbBrush}" CornerRadius="4" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Width" Value="10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                  CanContentScroll="{TemplateBinding CanContentScroll}"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Margin="{TemplateBinding Padding}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                     HorizontalAlignment="Right"
                                     Maximum="{TemplateBinding ScrollableHeight}"
                                     Orientation="Vertical"
                                     Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                     Value="{TemplateBinding VerticalOffset}"
                                     ViewportSize="{TemplateBinding ViewportHeight}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- MODERN PRIMARY BUTTON (SOLID)                  -->
        <!-- ==============================================- -->
        <Style x:Key="ModernPrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,14"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="{StaticResource AccentColor}" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- FILLED ACCENT BUTTON                           -->
        <!-- ==============================================- -->
        <Style x:Key="FilledButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="{StaticResource AccentHoverColor}" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="{StaticResource AccentColor}" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- CIRCLE BUTTON                                  -->
        <!-- ==============================================- -->
        <Style x:Key="CircleButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="{TemplateBinding Background}" x:Name="Bg" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.4"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Bg" 
                                                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)" 
                                                            To="#444444" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bg" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                             To="1.1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bg" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="1.1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Bg" 
                                                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)" 
                                                            To="#333333" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bg" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                             To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="Bg" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- ANDROID-STYLE TOGGLE SWITCH                    -->
        <!-- ==============================================- -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid Width="48" Height="26">
                                    <Border x:Name="Track" CornerRadius="13" BorderThickness="0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{StaticResource ToggleOffTrackColor}"/>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="ThumbBorder" Width="20" Height="20"
                                            CornerRadius="10" HorizontalAlignment="Left" Margin="3,0,0,0"
                                            Background="White">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                        </Border.RenderTransform>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                        </Border.Effect>
                                    </Border>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" To="22" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="Track" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="{StaticResource AccentColor}" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" 
                                                             Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="Track" 
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                            To="{StaticResource ToggleOffTrackColor}" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- MATERIAL RADIO BUTTON                          -->
        <!-- ==============================================- -->
        <Style x:Key="ModeRadioButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent" Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="OuterCircle" Width="20" Height="20"
                                     Stroke="{DynamicResource TextSecBrush}" StrokeThickness="2"
                                     VerticalAlignment="Center"/>
                            <Ellipse x:Name="InnerCircle" Width="10" Height="10"
                                     Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center"
                                     Opacity="0">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="InnerScale" ScaleX="0.5" ScaleY="0.5"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="InnerCircle" 
                                                             Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="InnerScale" 
                                                             Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase Amplitude="1" EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="InnerScale" 
                                                             Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase Amplitude="1" EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <ColorAnimation Storyboard.TargetName="OuterCircle" 
                                                            Storyboard.TargetProperty="(Ellipse.Stroke).(SolidColorBrush.Color)" 
                                                            To="{StaticResource AccentColor}" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="InnerCircle" 
                                                             Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="InnerScale" 
                                                             Storyboard.TargetProperty="ScaleX" To="0.5" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="InnerScale" 
                                                             Storyboard.TargetProperty="ScaleY" To="0.5" Duration="0:0:0.15"/>
                                            <ColorAnimation Storyboard.TargetName="OuterCircle" 
                                                            Storyboard.TargetProperty="(Ellipse.Stroke).(SolidColorBrush.Color)" 
                                                            To="{StaticResource TextSecondaryColor}" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- MODERN TEXT INPUT                              -->
        <!-- ==============================================- -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ControlBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" SnapsToDevicePixels="True">
                            <Grid Margin="{TemplateBinding Padding}">
                                <TextBlock x:Name="Placeholder" Text="{TemplateBinding Tag}"
                                           Foreground="{DynamicResource TextSecBrush}"
                                           FontSize="{TemplateBinding FontSize}"
                                           
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"
                                           Opacity="0.5"/>
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" 
                                              HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ==============================================- -->
        <!-- COMBOBOX STYLE                                 -->
        <!-- ==============================================- -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ==============================================- -->
        <!-- TEXT STYLES                                    -->
        <!-- ==============================================- -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="CardSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="SettingDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecBrush}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecBrush}"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- ==============================================- -->
        <!-- DEVICE SELECTOR RADIO BUTTON                   -->
        <!-- ==============================================- -->
        <Style x:Key="DeviceRadioButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="Transparent" Padding="16,14" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Left accent bar -->
                                <Border x:Name="AccentBar" Width="4" CornerRadius="2"
                                        Background="{DynamicResource AccentBrush}" Opacity="0"
                                        VerticalAlignment="Stretch">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleY="0.5"/>
                                    </Border.RenderTransform>
                                </Border>
                                <ContentPresenter Grid.Column="2" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A2D2A"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="AccentBar" 
                                                             Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="AccentBar" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="1" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="AccentBar" 
                                                             Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="AccentBar" 
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                             To="0.5" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#3A3D3A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#4A4D4A"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Notification Style -->
        <Style x:Key="NotificationBorder" TargetType="Border">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="MaxWidth" Value="350"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.4" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="ShowToast">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToastBorder" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
            </ObjectAnimationUsingKeyFrames>
            <DoubleAnimation Storyboard.TargetName="ToastTransform" 
                             Storyboard.TargetProperty="X" From="400" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ToastBorder" 
                             Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>

        <Storyboard x:Key="HideToast">
            <DoubleAnimation Storyboard.TargetName="ToastTransform" 
                             Storyboard.TargetProperty="X" To="400" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ToastBorder" 
                             Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ToastBorder" Storyboard.TargetProperty="Visibility">
                <DiscreteObjectKeyFrame KeyTime="0:0:0.4" Value="{x:Static Visibility.Collapsed}"/>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>

        <Storyboard x:Key="ToastTimerAnim">
            <DoubleAnimation Storyboard.TargetName="ToastTimer" 
                             Storyboard.TargetProperty="Width" From="320" To="0" Duration="0:0:4"/>
        </Storyboard>

        <Storyboard x:Key="TabFadeIn">
            <DoubleAnimation Storyboard.TargetName="MainTabs" 
                             Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" 
                             Storyboard.TargetName="MainTabs"
                             From="15" To="0" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ==============================================- -->
        <!-- MAIN CONTENT AREA                              -->
        <!-- ==============================================- -->
        <Grid Grid.Row="0">
            <TabControl x:Name="MainTabs" Background="Transparent" BorderThickness="0" SelectedIndex="0">
                <TabControl.RenderTransform>
                    <TranslateTransform Y="0"/>
                </TabControl.RenderTransform>
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent"/>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- ======================================== -->
                <!-- TAB 1: SERVER                           -->
                <!-- ======================================== -->
                <TabItem>
                    <Grid x:Name="ServerTabRoot">
                        <Grid.Resources>
                        </Grid.Resources>

                        <!-- ==- Main Server View ==- -->
                        <ScrollViewer x:Name="ServerMainView" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.RenderTransform>
                                <TranslateTransform x:Name="ServerMainViewTransform"/>
                            </ScrollViewer.RenderTransform>
                            <Grid Margin="48,36,48,24" HorizontalAlignment="Center" MaxWidth="820">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MaxWidth="480"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="260"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <!-- Server Info Card -->
                                    <Border Style="{StaticResource ModernCard}">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock x:Name="LblServerTabTitle" Text="{DynamicResource LblServerTabTitle}" Style="{StaticResource CardTitle}"/>
                                            </Grid>
                                            <TextBlock x:Name="LblServerTabDesc" Text="{DynamicResource LblServerTabDesc}"
                                                       Style="{StaticResource CardSubtitle}" Margin="0,6,0,24"/>

                                            <!-- Send Audio -->
                                            <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerBrush}"
                                                    Padding="0,20,0,16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Foreground="{DynamicResource AccentBrush}" Text="{DynamicResource IconAudio}" FontFamily="Segoe MDL2 Assets" FontSize="20" VerticalAlignment="Top" Margin="5"/>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                        <TextBlock x:Name="LblSendAudio" Text="{DynamicResource LblSendAudio}" Style="{StaticResource SettingLabel}"/>
                                                        <TextBlock x:Name="LblSendAudioDesc" Text="{DynamicResource LblSendAudioDesc}"
                                                                   Style="{StaticResource SettingDescription}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Connections Section -->
                                    <TextBlock x:Name="LblConnections" Text="{DynamicResource LblConnections}" Style="{StaticResource SectionHeader}"
                                               Margin="0,36,0,16"/>
                                    <Border Style="{StaticResource ModernCard}" Padding="24,20">
                                        <TextBlock x:Name="TxtConnections" Text="{Binding ViewModel.AppStatusText}"
                                                   HorizontalAlignment="Center" Margin="0,8">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource CardSubtitle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ViewModel.IsClientConnected}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>

                                <!-- Right Column -->
                                <StackPanel Grid.Column="2">
                                    <!-- Host Info -->
                                    <Border Style="{StaticResource ModernCard}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtHostName" Text="{Binding ViewModel.HostName}"
                                                       Style="{StaticResource CardTitle}"/>
                                            <TextBlock x:Name="TxtLocalIps" Text="{Binding ViewModel.LocalIps}"
                                                       Style="{StaticResource CardSubtitle}" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Audio Device Button -->
                                    <Border Style="{StaticResource ModernCard}" Padding="16">
                                        <StackPanel>
                                            <TextBlock x:Name="LblAudioDevice" Text="{DynamicResource LblAudioDevice}" Style="{StaticResource CardTitle}"
                                                       Margin="8,0,0,4"/>
                                            <TextBlock x:Name="LblAudioDeviceDesc" Text="{DynamicResource LblAudioDeviceDesc}"
                                                       Style="{StaticResource CardSubtitle}" Margin="8,0,0,12"/>
                                            <Button x:Name="BtnSelectDevice" Click="BtnSelectDevice_Click"
                                                     Style="{StaticResource DeviceChoiceButtonStyle}"
                                                     Content="{Binding ViewModel.SelectedCaptureDevice.Name, FallbackValue='System Default Device'}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- ==- Device Picker View (overlays on top) ==- -->
                        <Grid x:Name="DevicePickerView" Background="{DynamicResource BgBrush}" Visibility="Collapsed" Opacity="0">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="DevicePickerTransform" X="400"/>
                            </Grid.RenderTransform>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="48,36,48,24" HorizontalAlignment="Center" MaxWidth="520">
                                    <!-- Back button + title -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                        <Button x:Name="BtnBackFromDevices" Click="BtnBackFromDevices_Click"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Foreground="{DynamicResource AccentBrush}" Padding="8,4" Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Root" Background="{TemplateBinding Background}" 
                                                            Padding="{TemplateBinding Padding}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path x:Name="Arrow" Data="M8,16 L0,8 L8,0" Stroke="{TemplateBinding Foreground}" 
                                                                  StrokeThickness="2.5" Width="10" Height="16" Stretch="Uniform" Margin="0,0,10,0" 
                                                                  VerticalAlignment="Center" StrokeStartLineCap="Round" 
                                                                  StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                                            <TextBlock x:Name="Text" Text="BACK" FontSize="14" FontWeight="Bold" 
                                                                       Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#224CAF50"/>
                                                            <Setter Property="Foreground" Value="#66FF66"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#444CAF50"/>
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>

                                    <Border Style="{StaticResource ModernCard}" Padding="20">
                                        <StackPanel>
                                            <TextBlock x:Name="LblSelectAudioDevice" Text="{DynamicResource LblSelectAudioDevice}" Style="{StaticResource CardTitle}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="LblSelectAudioDeviceDesc" Text="{DynamicResource LblSelectAudioDeviceDesc}"
                                                       Style="{StaticResource CardSubtitle}" Margin="0,0,0,16"/>
                                             <ListBox x:Name="DeviceList" 
                                                      ItemsSource="{Binding ViewModel.CaptureDevices}"
                                                      SelectedItem="{Binding ViewModel.SelectedCaptureDevice}"
                                                      Background="Transparent" BorderThickness="0"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                 <ListBox.ItemContainerStyle>
                                                     <Style TargetType="ListBoxItem">
                                                         <Setter Property="Padding" Value="0"/>
                                                         <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                         <Setter Property="Background" Value="Transparent"/>
                                                         <Setter Property="BorderThickness" Value="0"/>
                                                         <Setter Property="Template">
                                                             <Setter.Value>
                                                                 <ControlTemplate TargetType="ListBoxItem">
                                                                     <Border Background="{TemplateBinding Background}" IsHitTestVisible="True">
                                                                         <ContentPresenter/>
                                                                     </Border>
                                                                 </ControlTemplate>
                                                             </Setter.Value>
                                                         </Setter>
                                                     </Style>
                                                 </ListBox.ItemContainerStyle>
                                                 <ListBox.ItemTemplate>
                                                     <DataTemplate>
                                                         <RadioButton IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=TwoWay}"
                                                                      Style="{StaticResource DeviceRadioButton}"
                                                                      
                                                                      Content="{Binding Name}"/>
                                                     </DataTemplate>
                                                 </ListBox.ItemTemplate>
                                             </ListBox>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ======================================== -->
                <!-- TAB 2: PLAYER                           -->
                <!-- ======================================== -->
                <TabItem>
                    <Grid x:Name="PlayerTabRoot">
                        <Grid.Resources>
                            <Storyboard x:Key="TransitionToStats">
                                <DoubleAnimation Storyboard.TargetName="PlayerHeaderCard" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="PlayerConnectCard" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="PlayerDiscoveryCard" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerHeaderCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerConnectCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerDiscoveryCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerStatsView" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <DoubleAnimation Storyboard.TargetName="PlayerStatsView" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.2"/>
                            </Storyboard>

                            <Storyboard x:Key="TransitionToConnect">
                                <DoubleAnimation Storyboard.TargetName="PlayerStatsView" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerStatsView" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerHeaderCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerConnectCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerDiscoveryCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <DoubleAnimation Storyboard.TargetName="PlayerHeaderCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="PlayerConnectCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="PlayerDiscoveryCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.2"/>
                            </Storyboard>
                        </Grid.Resources>

                        <ScrollViewer x:Name="PlayerMainView" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.RenderTransform>
                                <TranslateTransform x:Name="PlayerMainViewTransform"/>
                            </ScrollViewer.RenderTransform>
                            <Grid Margin="48,36,48,24" HorizontalAlignment="Center" MaxWidth="850">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="400" MaxWidth="500"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="280"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <!-- Player Header Card -->
                                    <Border x:Name="PlayerHeaderCard" Style="{StaticResource ModernCard}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="Player" Style="{StaticResource CardTitle}"/>
                                            </Grid>
                                            <TextBlock Text="Receive the audio of another device" Style="{StaticResource CardSubtitle}" Margin="0,4,0,16"/>
                                            <Border BorderThickness="0,1,0,0" BorderBrush="{DynamicResource DividerBrush}" Margin="0,0,0,16"/>

                                            <!-- Features List -->
                                            <StackPanel>
                                                <Grid Margin="0,0,0,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="32"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{DynamicResource IconAudio}" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                        <TextBlock Text="Receive audio" Style="{StaticResource SettingLabel}"/>
                                                        <TextBlock Text="Listen to the audio of another device on this computer" Style="{StaticResource SettingDescription}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,0,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="32"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{DynamicResource IconMic}" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Top" Margin="0,2,0,0"/>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                        <TextBlock Text="Receive mic input" Style="{StaticResource SettingLabel}"/>
                                                        <TextBlock Text="Use another device as mic input" Style="{StaticResource SettingDescription}"/>
                                                        <TextBlock Text="A virtual audio device is necessary" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>

                                        </StackPanel>
                                    </Border>

                                    <!-- Connect by address Card -->
                                    <Border x:Name="PlayerConnectCard" Style="{StaticResource ModernCard}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Connect by address" Style="{StaticResource CardTitle}"/>
                                            <TextBlock Text="IP address or hostname" Style="{StaticResource CardSubtitle}" Margin="0,4,0,16"/>
                                            
                                            <!-- Connection Inputs -->
                                            <StackPanel Margin="0,0,0,24">
                                                <TextBox x:Name="InputAndroidIp" Text="{Binding ViewModel.TargetIp, UpdateSourceTrigger=PropertyChanged}" 
                                                         Style="{StaticResource ModernTextBox}" Padding="12,10" Tag="e.g. 192.168.1.5"/>
                                            </StackPanel>

                                             <Button x:Name="BtnConnectPlayer" 
                                                     Style="{StaticResource ModernPrimaryButton}" 
                                                     Width="200" Height="50" HorizontalAlignment="Center"
                                                     Command="{Binding ViewModel.ToggleConnectPlayerCommand}"
                                                     IsEnabled="{Binding ViewModel.IsPlayerConnecting, Converter={StaticResource InverseBooleanConverter}, FallbackValue=True}">
                                                 <TextBlock x:Name="BtnConnectText" 
                                                            Text="{Binding ViewModel.PlayerStatusText, FallbackValue='CONNECT'}"
                                                            FontSize="15" FontWeight="Bold" />
                                             </Button>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel x:Name="PlayerDiscoveryCard">
                                        <!-- Servers Section -->
                                        <Grid Margin="12,0,4,12">
                                            <TextBlock Text="Servers" Style="{StaticResource SectionHeader}" Margin="0" FontSize="18" VerticalAlignment="Center"/>
                                            <CheckBox x:Name="ChkAutoConnect" Content="{DynamicResource ChkAutoConnect}"
                                                      Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right"
                                                      Foreground="{DynamicResource TextSecBrush}" VerticalAlignment="Center"
                                                      IsChecked="{Binding ViewModel.AutoConnect}"/>
                                        </Grid>
                                         <ListBox x:Name="DiscoveredDevicesList" 
                                                  ItemsSource="{Binding ViewModel.DiscoveredServers}"
                                                  Background="Transparent" BorderThickness="0"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                             <ListBox.ItemContainerStyle>
                                                 <Style TargetType="ListBoxItem">
                                                     <Setter Property="Template">
                                                         <Setter.Value>
                                                             <ControlTemplate TargetType="ListBoxItem">
                                                                 <ContentPresenter/>
                                                             </ControlTemplate>
                                                         </Setter.Value>
                                                     </Setter>
                                                 </Style>
                                             </ListBox.ItemContainerStyle>
                                             <ListBox.ItemTemplate>
                                                 <DataTemplate>
                                                     <Button Style="{StaticResource ServerItemButtonStyle}"
                                                             Command="{Binding DataContext.ViewModel.ConnectToServiceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                             CommandParameter="{Binding}">
                                                         <Grid>
                                                             <Grid.ColumnDefinitions>
                                                                 <ColumnDefinition Width="48"/>
                                                                 <ColumnDefinition Width="*"/>
                                                                 <ColumnDefinition Width="30"/>
                                                             </Grid.ColumnDefinitions>
                                                             <TextBlock Text="{DynamicResource IconMobile}" FontFamily="Segoe MDL2 Assets" 
                                                                        FontSize="24" VerticalAlignment="Center" 
                                                                        HorizontalAlignment="Left" Opacity="0.8" 
                                                                        Foreground="{DynamicResource AccentBrush}"/>
                                                             <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                                                                 <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="15" 
                                                                            Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                 <TextBlock Text="{Binding IpAddress}" FontSize="13" 
                                                                            Foreground="{DynamicResource TextSecBrush}" Margin="0,2,0,0"/>
                                                             </StackPanel>
                                                             <TextBlock Grid.Column="2" Text=">" FontSize="28" VerticalAlignment="Center" 
                                                                        HorizontalAlignment="Right" Foreground="{DynamicResource TextSecBrush}"/>
                                                         </Grid>
                                                     </Button>
                                                 </DataTemplate>
                                             </ListBox.ItemTemplate>
                                         </ListBox>
                                         <Border Style="{StaticResource ModernCard}" Padding="20" Opacity="0.6"
                                                 Visibility="{Binding ViewModel.DiscoveredServers.Count, Converter={StaticResource InverseCountToVisibilityConverter}, FallbackValue=Visible}">
                                             <TextBlock Text="No server found" Style="{StaticResource CardSubtitle}" 
                                                        HorizontalAlignment="Center" Margin="0"/>
                                         </Border>
                                    </StackPanel>

                                     <!-- Stats Card (Connected Mode) -->
                                     <StackPanel x:Name="PlayerStatsView" Visibility="{Binding ViewModel.IsStatsVisible, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                                        <Border Style="{StaticResource ModernCard}" Margin="0,0,0,16">
                                            <StackPanel>
                                                <Grid Margin="0,12,0,24">
                                                    <TextBlock Margin="0,-6,12,0" Text="Connection" Style="{StaticResource CardTitle}"/>
                                                    <TextBlock Margin="0,0,12,0" Text="{Binding ViewModel.ConnectTime}" HorizontalAlignment="Right" Style="{StaticResource CardSubtitle}"/>
                                                </Grid>
                                                
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="48"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{DynamicResource IconDiscovery}" FontFamily="Segoe MDL2 Assets" FontSize="26" VerticalAlignment="Center" 
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                     <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                         <TextBlock x:Name="TxtActiveDeviceName" Text="{Binding ViewModel.ActiveDeviceName}" Style="{StaticResource SettingLabel}"/>
                                                         <TextBlock x:Name="TxtActiveDeviceIp" Text="{Binding ViewModel.ActiveDeviceIp}" Style="{StaticResource SettingDescription}"/>
                                                     </StackPanel>

                                                    <!-- Floating Stop Button positioned at the corner -->
                                     <Button Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                                             Width="48" Height="48" Margin="0,10,0,-66" Command="{Binding ViewModel.ToggleConnectPlayerCommand}"
                                            Background="#333333" BorderThickness="0" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Ellipse Fill="{TemplateBinding Background}" x:Name="Bg" RenderTransformOrigin="0.5,0.5">
                                                        <Ellipse.RenderTransform>
                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                        </Ellipse.RenderTransform>
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.4"/>
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Border Width="14" Height="14" Background="White" CornerRadius="2"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation Storyboard.TargetName="Bg" 
                                                                                    Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)" 
                                                                                    To="#444444" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="Bg" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                                                     To="1.1" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="Bg" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                                                     To="1.1" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation Storyboard.TargetName="Bg" 
                                                                                    Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)" 
                                                                                    To="#333333" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="Bg" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                                                                                     To="1" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="Bg" 
                                                                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                                                                                     To="1" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource ModernCard}" Margin="0,16,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="1"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <TextBlock Text="{DynamicResource IconBuffer}" FontFamily="Segoe MDL2 Assets" 
                                                                                   Margin="0,0,8,0" VerticalAlignment="Center" 
                                                                                   Foreground="{DynamicResource AccentBrush}" FontSize="16"/>
                                                        <TextBlock Margin="0,5,0,0" Text="BUFFER" Style="{StaticResource StatLabel}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ViewModel.BufferDelay}" Style="{StaticResource StatValue}" Margin="24,0,0,0"/>
                                                </StackPanel>

                                                <Border Grid.Column="1" Background="{DynamicResource DividerBrush}" Margin="8,4"/>

                                                <StackPanel Grid.Column="2" Margin="16,0,0,0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <TextBlock Text="{DynamicResource IconLatency}" FontFamily="Segoe MDL2 Assets" 
                                                                                   Margin="0,0,8,0" VerticalAlignment="Center" 
                                                                                   Foreground="{DynamicResource AccentBrush}" FontSize="16"/>
                                                        <TextBlock Margin="0,5,0,0" Text="LATENCY" Style="{StaticResource StatLabel}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="24,0,0,0">
                                                        <TextBlock Text="Average" Style="{StaticResource SettingDescription}"/>
                                                        <TextBlock Text="{Binding ViewModel.AverageLatency}" Style="{StaticResource StatValue}" FontSize="14"/>
                                                        <TextBlock Text="Max" Style="{StaticResource SettingDescription}" Margin="0,4,0,0"/>
                                                        <TextBlock Text="{Binding ViewModel.MaxLatency}" Style="{StaticResource StatValue}" FontSize="14"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right Column (Mode Selection) -->
                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource ModernCard}">
                                        <StackPanel>
                                            <TextBlock Text="Mode" Style="{StaticResource CardTitle}" Margin="0,0,0,20"/>
                                            <RadioButton IsChecked="True" Style="{StaticResource ModeRadioButton}"
                                                         GroupName="PlayerMode">
                                                <StackPanel>
                                                    <TextBlock Text="Mic" Style="{StaticResource SettingLabel}"/>
                                                    <TextBlock Text="Use your phone's mic"
                                                               Style="{StaticResource SettingDescription}"/>
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton Style="{StaticResource ModeRadioButton}"
                                                         GroupName="PlayerMode" Margin="0,14,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Playback" Style="{StaticResource SettingLabel}"/>
                                                    <TextBlock Text="Listen to another device"
                                                               Style="{StaticResource SettingDescription}"/>
                                                </StackPanel>
                                            </RadioButton>

                                            <TextBlock Text="Output Device" Style="{StaticResource SettingDescription}"
                                                       Margin="0,28,0,10"/>
                                             <Button x:Name="BtnSelectOutputDevice" Click="BtnSelectOutputDevice_Click"
                                                       Style="{StaticResource DeviceChoiceButtonStyle}"
                                                       Content="{Binding ViewModel.SelectedOutputDevice.Name, FallbackValue='System Default Device'}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                    <!-- ==- Output Device Picker View (overlays on top) ==- -->
                    <Grid x:Name="OutputDevicePickerView" Background="{DynamicResource BgBrush}" Visibility="Collapsed" Opacity="0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="OutputDevicePickerTransform" X="400"/>
                        </Grid.RenderTransform>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="48,36,48,24" HorizontalAlignment="Center" MaxWidth="520">
                                <!-- Back button + title -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <Button x:Name="BtnBackFromOutputDevices" Click="BtnBackFromOutputDevices_Click"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Foreground="{DynamicResource AccentBrush}" Padding="8,4" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Root" Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path x:Name="Arrow" Data="M8,16 L0,8 L8,0" Stroke="{TemplateBinding Foreground}" 
                                                              StrokeThickness="2.5" Width="10" Height="16" Stretch="Uniform" Margin="0,0,10,0" 
                                                              VerticalAlignment="Center" StrokeStartLineCap="Round" 
                                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                                        <TextBlock x:Name="Text" Text="BACK" FontSize="14" FontWeight="Bold" 
                                                                   Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#224CAF50"/>
                                                        <Setter Property="Foreground" Value="#66FF66"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#444CAF50"/>
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <Border Style="{StaticResource ModernCard}" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="Select output device" Style="{StaticResource CardTitle}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Choose which audio device to play receiving audio"
                                                   Style="{StaticResource CardSubtitle}" Margin="0,0,0,16"/>
                                        <ListBox x:Name="OutputDeviceList" 
                                                 ItemsSource="{Binding ViewModel.OutputDevices}"
                                                 SelectedItem="{Binding ViewModel.SelectedOutputDevice}"
                                                 Background="Transparent" BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                              <ListBox.ItemContainerStyle>
                                                  <Style TargetType="ListBoxItem">
                                                      <Setter Property="Padding" Value="0"/>
                                                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                      <Setter Property="Background" Value="Transparent"/>
                                                      <Setter Property="BorderThickness" Value="0"/>
                                                      <Setter Property="Template">
                                                          <Setter.Value>
                                                              <ControlTemplate TargetType="ListBoxItem">
                                                                  <Border Background="{TemplateBinding Background}" IsHitTestVisible="True">
                                                                      <ContentPresenter/>
                                                                  </Border>
                                                              </ControlTemplate>
                                                          </Setter.Value>
                                                      </Setter>
                                                  </Style>
                                              </ListBox.ItemContainerStyle>
                                              <ListBox.ItemTemplate>
                                                  <DataTemplate>
                                                      <RadioButton IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Mode=TwoWay}"
                                                                   Style="{StaticResource DeviceRadioButton}"
                                                                   
                                                                   Content="{Binding Name}"/>
                                                  </DataTemplate>
                                              </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

                <!-- ======================================== -->
                <!-- TAB 3: SETTINGS                         -->
                <!-- ======================================== -->
                <TabItem>
                    <ScrollViewer Margin="48,36,48,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="540" HorizontalAlignment="Center">

                            <!-- DISPLAY SECTION -->
                            <TextBlock Text="Display" Margin="12,0,0,20" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource ModernCard}" Padding="0">
                                <StackPanel>
                                    <!-- Device Name -->
                                    <Border Padding="24,20" BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource DividerBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock x:Name="LblDeviceName" Text="{DynamicResource LblDeviceName}" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock x:Name="LblDeviceNameDesc" Text="{DynamicResource LblDeviceNameDesc}"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                             <TextBox x:Name="TxtDeviceName" Grid.Column="1" Text="{Binding ViewModel.DeviceName, UpdateSourceTrigger=PropertyChanged}" 
                                                      HorizontalAlignment="Right" Width="180"
                                                      Style="{StaticResource ModernTextBox}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Dark Theme -->
                                    <Border Padding="24,20" BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource DividerBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="LblDarkTheme" Text="{DynamicResource LblDarkTheme}" Style="{StaticResource SettingLabel}"
                                                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                                             <CheckBox x:Name="ChkDarkTheme" Grid.Column="1" IsChecked="{Binding ViewModel.IsDarkTheme}" Style="{StaticResource ToggleSwitch}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <!-- Minimize Window -->
                                    <Border Padding="24,20" BorderThickness="0,0,0,1"
                                            BorderBrush="{DynamicResource DividerBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock x:Name="LblTray" Text="{DynamicResource LblTray}" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock x:Name="LblTrayDesc" Text="{DynamicResource LblTrayDesc}"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                             <CheckBox x:Name="ChkMinimizeToTray" Grid.Column="1" IsChecked="{Binding ViewModel.MinimizeToTray}" Style="{StaticResource ToggleSwitch}"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <!-- Language -->
                                    <Border Padding="24,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock x:Name="LblLanguage" Text="{DynamicResource LblLanguage}" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock x:Name="LblLanguageDesc" Text="{DynamicResource LblLanguageDesc}"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                             <Button x:Name="BtnLanguage" Grid.Column="1" Content="{Binding ViewModel.Language}" HorizontalAlignment="Right"
                                                     Style="{StaticResource DeviceChoiceButtonStyle}"
                                                     MinWidth="100" Padding="12,8"
                                                     Command="{Binding ViewModel.ToggleLanguageCommand}"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- STARTUP SECTION -->
                            <TextBlock Text="Startup" Style="{StaticResource SectionHeader}" Margin="12,36,0,20"/>
                            <Border Style="{StaticResource ModernCard}" Padding="0">
                                <Border Padding="24,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="LblStartup" Text="{DynamicResource LblStartup}"
                                                   Style="{StaticResource SettingLabel}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                         <CheckBox x:Name="ChkStartup" Grid.Column="1" IsChecked="{Binding ViewModel.LaunchOnStartup}" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right"/>
                                    </Grid>
                                </Border>
                            </Border>

                            <!-- AUDIO SECTION -->
                            <TextBlock Text="Audio" Style="{StaticResource SectionHeader}" Margin="12,36,0,20"/>
                            <Border Style="{StaticResource ModernCard}" Padding="0">
                                <StackPanel>
                                    <Border Padding="24,20" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource DividerBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock x:Name="LblAutoMute" Text="{DynamicResource LblAutoMute}"
                                                           Style="{StaticResource SettingLabel}"/>
                                                <TextBlock x:Name="LblAutoMuteDesc" Text="{DynamicResource LblAutoMuteDesc}"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                             <CheckBox x:Name="ChkAutoMute" Grid.Column="1" IsChecked="{Binding ViewModel.AutoMute}" Style="{StaticResource ToggleSwitch}" 
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                    <Border Padding="24,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock x:Name="LblLogs" Text="{DynamicResource LblLogs}" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock x:Name="LblLogsDesc" Text="{DynamicResource LblLogsDesc}"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="OPEN LOGS" Click="BtnShowLogs_Click" 
                                                    HorizontalAlignment="Right" Background="Transparent"
                                                    Foreground="{DynamicResource AccentBrush}"
                                                    BorderThickness="0" FontWeight="SemiBold"
                                                    FontSize="14" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ==============================================- -->
        <!-- BOTTOM NAVIGATION BAR                          -->
        <!-- ==============================================- -->
        <Border Grid.Row="1" Background="{DynamicResource BottomBarBrush}"
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,4,0,4">
                <RadioButton IsChecked="True" Style="{StaticResource NavButtonStyle}"
                             Checked="Nav_Click" Name="NavServer">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource IconServer}" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock x:Name="NavServerText" Text="{DynamicResource NavServerText}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton Style="{StaticResource NavButtonStyle}"
                             Checked="Nav_Click" Name="NavPlayer">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource IconPlayer}" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock x:Name="NavPlayerText" Text="{DynamicResource NavPlayerText}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton Style="{StaticResource NavButtonStyle}"
                             Checked="Nav_Click" Name="NavSettings">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{DynamicResource IconSettings}" FontFamily="Segoe MDL2 Assets" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock x:Name="NavSettingsText" Text="{DynamicResource NavSettingsText}" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>

        <!-- ==============================================- -->
        <!-- NOTIFICATION OVERLAY                           -->
        <!-- ==============================================- -->
        <Grid Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top" 
              Margin="0,20,20,0" >
            <Border x:Name="ToastBorder" Style="{StaticResource NotificationBorder}" 
                    Visibility="Collapsed" Opacity="0" IsHitTestVisible="True"
                    Width="320">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastTransform" X="400"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="16,0,36,16">
                        <TextBlock x:Name="TxtToastTitle" Text="NOTIFICATION" FontWeight="Bold" 
                                   Foreground="{DynamicResource AccentBrush}" FontSize="18" 
                                   Margin="0,0,0,12"/>
                        <TextBlock x:Name="TxtToastMessage" Text="Notification message here" 
                                   Foreground="White" FontSize="16" TextWrapping="Wrap" Opacity="0.9"/>
                    </StackPanel>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Style="{StaticResource GhostButton}" Click="BtnCloseToast_Click"
                            Margin="0,4,4,0" Padding="8,4" BorderThickness="0">
                        <TextBlock Text="{DynamicResource IconClose}" FontFamily="Segoe MDL2 Assets" Margin="4" FontSize="12" Foreground="#88FFFFFF"/>
                    </Button>

                    <Rectangle x:Name="ToastTimer" Grid.Row="1" Height="3" 
                               HorizontalAlignment="Left"
                               Fill="{DynamicResource AccentBrush}" 
                               Width="320" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</Window>



