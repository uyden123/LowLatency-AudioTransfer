<Window x:Class="AudioTransfer.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioTransfer.GUI"
        mc:Ignorable="d"
        Title="AudioTransfer" Height="680" Width="1050"
        Background="#1E1E1E" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.ClearTypeHint="Enabled"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- ═══════════════════════════════════════════════ -->
        <!-- ANDROID MATERIAL DARK — GREEN ACCENT           -->
        <!-- ═══════════════════════════════════════════════ -->
        <Color x:Key="BgColor">#1E1E1E</Color>
        <Color x:Key="SurfaceColor">#2D2D2D</Color>
        <Color x:Key="BottomBarColor">#252525</Color>
        <Color x:Key="CardColor">#2D2D2D</Color>
        <Color x:Key="AccentColor">#4CAF50</Color>
        <Color x:Key="AccentHoverColor">#43A047</Color>
        <Color x:Key="AccentPressColor">#388E3C</Color>
        <Color x:Key="AccentDimColor">#1A4CAF50</Color>
        <Color x:Key="AccentPressBgColor">#334CAF50</Color>
        <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
        <Color x:Key="TextSecondaryColor">#9E9E9E</Color>
        <Color x:Key="DividerColor">#383838</Color>
        <Color x:Key="HoverColor">#333333</Color>
        <Color x:Key="InputBgColor">#353535</Color>
        <Color x:Key="InputBorderColor">#444444</Color>
        <Color x:Key="WarningBgColor">#2A2520</Color>
        <Color x:Key="WarningColor">#FFB74D</Color>
        <Color x:Key="ToggleOffTrackColor">#555555</Color>

        <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="BottomBarBrush" Color="{StaticResource BottomBarColor}"/>
        <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecBrush" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="DividerBrush" Color="{StaticResource DividerColor}"/>
        <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- BOTTOM NAV BUTTON (horizontal, icon + label)   -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9E9E9E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Margin="0,8,0,6">
                                <!-- Top accent indicator -->
                                <Border x:Name="Indicator" Height="3" Width="32"
                                        HorizontalAlignment="Center" Margin="0,0,0,6"
                                        Background="{StaticResource AccentBrush}" Visibility="Collapsed"
                                        CornerRadius="0,0,2,2"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MODERN CARD                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" Direction="-90" RenderingBias="Quality"
                                      ShadowDepth="3" Opacity="0.15" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PRIMARY BUTTON (outlined accent)               -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource AccentDimColor}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource AccentPressBgColor}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- CUSTOM SCROLLBAR                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Root">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#44FFFFFF" CornerRadius="4" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Width" Value="10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                  CanContentScroll="{TemplateBinding CanContentScroll}"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Margin="{TemplateBinding Padding}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                     HorizontalAlignment="Right"
                                     Maximum="{TemplateBinding ScrollableHeight}"
                                     Orientation="Vertical"
                                     Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                     Value="{TemplateBinding VerticalOffset}"
                                     ViewportSize="{TemplateBinding ViewportHeight}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- FILLED ACCENT BUTTON                           -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="FilledButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="{StaticResource AccentColor}"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource AccentHoverColor}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource AccentPressColor}"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- CIRCLE BUTTON                                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="CircleButton" TargetType="Button">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#383838"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="20" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ANDROID-STYLE TOGGLE SWITCH                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid Width="48" Height="26">
                                    <Border x:Name="Track" CornerRadius="13" BorderThickness="0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{StaticResource ToggleOffTrackColor}"/>
                                        </Border.Background>
                                    </Border>
                                    <Border x:Name="ThumbBorder" Width="20" Height="20"
                                            CornerRadius="10" HorizontalAlignment="Left" Margin="3,0,0,0"
                                            Background="White">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                                        </Border.Effect>
                                    </Border>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource AccentColor}"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="ThumbBorder" Property="Background" Value="White"/>
                                <Setter TargetName="ThumbBorder" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="ThumbBorder" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MATERIAL RADIO BUTTON                          -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="ModeRadioButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="Transparent" Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="OuterCircle" Width="20" Height="20"
                                     Stroke="{StaticResource TextSecBrush}" StrokeThickness="2"
                                     VerticalAlignment="Center"/>
                            <Ellipse x:Name="InnerCircle" Width="10" Height="10"
                                     Fill="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                     Visibility="Collapsed"/>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OuterCircle" Property="Stroke" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="InnerCircle" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MODERN TEXT INPUT                              -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- COMBOBOX STYLE                                 -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- TEXT STYLES                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <Style x:Key="CardTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="CardSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SettingLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="SettingDescription" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecBrush}"/>
        </Style>

        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- DEVICE SELECTOR RADIO BUTTON                   -->
        <!-- ═══════════════════════════════════════════════ -->
        <Style x:Key="DeviceRadioButton" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root" Background="Transparent" Padding="16,14" CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Left accent bar -->
                                <Border x:Name="AccentBar" Width="4" CornerRadius="2"
                                        Background="{StaticResource AccentBrush}" Visibility="Collapsed"
                                        VerticalAlignment="Stretch"/>
                                <ContentPresenter Grid.Column="2" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Root" Property="Background" Value="#2A2D2A"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="#333333"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- MAIN CONTENT AREA                              -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="0">
            <TabControl x:Name="MainTabs" Background="Transparent" BorderThickness="0" SelectedIndex="0">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <ContentPresenter ContentSource="SelectedContent"/>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- ════════════════════════════════════════ -->
                <!-- TAB 1: SERVER                           -->
                <!-- ════════════════════════════════════════ -->
                <TabItem>
                    <Grid x:Name="ServerTabRoot">
                        <Grid.Resources>
                            <!-- Animation to slide main view back in -->
                            <Storyboard x:Key="SlideInMain">
                                <DoubleAnimation Storyboard.TargetName="ServerMainViewTransform" 
                                                 Storyboard.TargetProperty="X" From="-400" To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="ServerMainView" 
                                                 Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                            </Storyboard>
                            <!-- Animation to slide picker in -->
                            <Storyboard x:Key="SlideInPicker">
                                <DoubleAnimation Storyboard.TargetName="DevicePickerTransform" 
                                                 Storyboard.TargetProperty="X" From="400" To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="DevicePickerView" 
                                                 Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                            </Storyboard>
                        </Grid.Resources>

                        <!-- ═══ Main Server View ═══ -->
                        <ScrollViewer x:Name="ServerMainView" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.RenderTransform>
                                <TranslateTransform x:Name="ServerMainViewTransform"/>
                            </ScrollViewer.RenderTransform>
                            <Grid Margin="48,36,48,24" HorizontalAlignment="Center" MaxWidth="820">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MaxWidth="480"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="260"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <!-- Server Info Card -->
                                    <Border Style="{StaticResource ModernCard}">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="Server" Style="{StaticResource CardTitle}"/>
                                            </Grid>
                                            <TextBlock Text="Send audio from this device to another"
                                                       Style="{StaticResource CardSubtitle}" Margin="0,6,0,24"/>

                                            <!-- Send Audio -->
                                            <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource DividerBrush}"
                                                    Padding="0,20,0,16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="40"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Foreground="#4CAF50" Text="🔊" FontSize="20" VerticalAlignment="Top" Margin="5"/>
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                        <TextBlock Text="Send audio" Style="{StaticResource SettingLabel}"/>
                                                        <TextBlock Text="Send the audio played on this computer to another device"
                                                                   Style="{StaticResource SettingDescription}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- Connections Section -->
                                    <TextBlock Text="Connections" Style="{StaticResource SectionHeader}"
                                               Margin="0,36,0,16"/>
                                    <Border Style="{StaticResource ModernCard}" Padding="24,20">
                                        <TextBlock x:Name="TxtConnections" Text="No connected device yet"
                                                   Style="{StaticResource CardSubtitle}"
                                                   HorizontalAlignment="Center" Margin="0,8"/>
                                    </Border>
                                </StackPanel>

                                <!-- Right Column -->
                                <StackPanel Grid.Column="2">
                                    <!-- Host Info -->
                                    <Border Style="{StaticResource ModernCard}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock x:Name="TxtHostName" Text="DESKTOP-PC"
                                                       Style="{StaticResource CardTitle}"/>
                                            <TextBlock x:Name="TxtLocalIps" Text="192.168.1.13"
                                                       Style="{StaticResource CardSubtitle}" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Audio Device Button -->
                                    <Border Style="{StaticResource ModernCard}" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="Audio device" Style="{StaticResource CardTitle}"
                                                       Margin="8,0,0,4"/>
                                            <TextBlock Text="Select which audio device to stream"
                                                       Style="{StaticResource CardSubtitle}" Margin="8,0,0,12"/>
                                            <Button x:Name="BtnSelectDevice" Click="BtnSelectDevice_Click"
                                                    Cursor="Hand" Background="#2A2A2E" Foreground="White"
                                                    BorderBrush="#444" BorderThickness="1"
                                                    Padding="14,12" HorizontalContentAlignment="Stretch">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                            <Grid>
                                                                <TextBlock x:Name="TxtSelectedDeviceName"
                                                                           Text="System default"
                                                                           Foreground="White" FontSize="13"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           VerticalAlignment="Center" Margin="0,0,30,0"/>
                                                                <Path Data="M0,0 L5,5 L0,10" 
                                                                      Stroke="{StaticResource AccentBrush}" 
                                                                      StrokeThickness="2" 
                                                                      Width="8" Height="12" 
                                                                      Stretch="Uniform" 
                                                                      HorizontalAlignment="Right" 
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,4,0" 
                                                                      StrokeStartLineCap="Round" 
                                                                      StrokeEndLineCap="Round" 
                                                                      StrokeLineJoin="Round"/>
                                                            </Grid>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>

                        <!-- ═══ Device Picker View (overlays on top) ═══ -->
                        <Grid x:Name="DevicePickerView" Background="#1E1E1E" Visibility="Collapsed" Opacity="0">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="DevicePickerTransform" X="400"/>
                            </Grid.RenderTransform>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="48,36,48,24" HorizontalAlignment="Center" MaxWidth="520">
                                    <!-- Back button + title -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                        <Button x:Name="BtnBackFromDevices" Click="BtnBackFromDevices_Click"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Foreground="#4CAF50" Padding="8,4" Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Root" Background="{TemplateBinding Background}" 
                                                            Padding="{TemplateBinding Padding}" CornerRadius="6">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Path x:Name="Arrow" Data="M8,16 L0,8 L8,0" Stroke="{TemplateBinding Foreground}" 
                                                                  StrokeThickness="2.5" Width="10" Height="16" Stretch="Uniform" Margin="0,0,10,0" 
                                                                  VerticalAlignment="Center" StrokeStartLineCap="Round" 
                                                                  StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                                            <TextBlock x:Name="Text" Text="BACK" FontSize="14" FontWeight="Bold" 
                                                                       Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#224CAF50"/>
                                                            <Setter Property="Foreground" Value="#66FF66"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Root" Property="Background" Value="#444CAF50"/>
                                                            <Setter Property="Opacity" Value="0.8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>

                                    <Border Style="{StaticResource ModernCard}" Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="Select audio device" Style="{StaticResource CardTitle}"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="Choose which audio output to capture and stream"
                                                       Style="{StaticResource CardSubtitle}" Margin="0,0,0,16"/>
                                            <StackPanel x:Name="DeviceList">
                                                <!-- Populated by code-behind -->
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ════════════════════════════════════════ -->
                <!-- TAB 2: PLAYER                           -->
                <!-- ════════════════════════════════════════ -->
                <TabItem>
                    <Grid x:Name="PlayerTabRoot">
                        <Grid.Resources>
                            <Storyboard x:Key="TransitionToStats">
                                <DoubleAnimation Storyboard.TargetName="PlayerConnectCard" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="PlayerDiscoveryCard" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerConnectCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerDiscoveryCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerStatsCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <DoubleAnimation Storyboard.TargetName="PlayerStatsCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="PlayerStatsCardTransform" Storyboard.TargetProperty="Y" From="20" To="0" Duration="0:0:0.3" BeginTime="0:0:0.2">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                            <Storyboard x:Key="TransitionToConnect">
                                <DoubleAnimation Storyboard.TargetName="PlayerStatsCard" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerStatsCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerConnectCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PlayerDiscoveryCard" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                                <DoubleAnimation Storyboard.TargetName="PlayerConnectCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetName="PlayerDiscoveryCard" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3" BeginTime="0:0:0.2"/>
                            </Storyboard>

                            <!-- Animation to slide main view back in -->
                            <Storyboard x:Key="SlideInOutputMain">
                                <DoubleAnimation Storyboard.TargetName="OutputDevicePickerTransform" 
                                                 Storyboard.TargetProperty="X" To="-400" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseIn"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="OutputDevicePickerView" 
                                                 Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                <DoubleAnimation Storyboard.TargetName="PlayerMainViewTransform" 
                                                 Storyboard.TargetProperty="X" From="400" To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="PlayerMainView" 
                                                 Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                            </Storyboard>
                            <!-- Animation to slide picker in -->
                            <Storyboard x:Key="SlideInOutputPicker">
                                <DoubleAnimation Storyboard.TargetName="OutputDevicePickerTransform" 
                                                 Storyboard.TargetProperty="X" From="400" To="0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="OutputDevicePickerView" 
                                                 Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                            </Storyboard>
                        </Grid.Resources>

                        <ScrollViewer x:Name="PlayerMainView" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.RenderTransform>
                                <TranslateTransform x:Name="PlayerMainViewTransform"/>
                            </ScrollViewer.RenderTransform>
                            <Grid Margin="48,36,48,24" HorizontalAlignment="Center" MaxWidth="820">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MaxWidth="480"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="260"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <!-- Connection Request Fields (Now at top) -->
                                    <Border x:Name="PlayerConnectCard" Style="{StaticResource ModernCard}">
                                        <StackPanel>
                                            <TextBlock Text="Connect to device" Style="{StaticResource CardTitle}"/>
                                            <TextBlock Text="Enter the IP of the remote Android device"
                                                       Style="{StaticResource CardSubtitle}" Margin="0,4,0,24"/>

                                            <TextBlock Text="Android IP Address" Style="{StaticResource SettingDescription}"
                                                       Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="90"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="InputAndroidIp" Text=""
                                                         Style="{StaticResource ModernTextBox}"/>
                                                <TextBox Grid.Column="2" x:Name="InputAndroidPort" Text="5003"
                                                         Style="{StaticResource ModernTextBox}"/>
                                            </Grid>

                                            <!-- Auto Connect Toggle -->
                                            <CheckBox x:Name="ChkAutoConnect" Content="Auto connect if last device found"
                                                      Style="{StaticResource ToggleSwitch}" Margin="0,16,0,0"
                                                      IsChecked="False" Click="ChkAutoConnect_Click"/>

                                            <Button x:Name="BtnConnectPlayer" Margin="0,16,0,0"
                                                    Style="{StaticResource FilledButton}" Height="42"
                                                    Click="BtnStartMic_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="BtnConnectIcon" Text="📡" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="BtnConnectText" Text="CONNECT" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="PlayerDiscoveryCard" Style="{StaticResource ModernCard}" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Discovered Devices" Style="{StaticResource CardTitle}"/>
                                            <TextBlock Text="Devices found on your local network"
                                                       Style="{StaticResource CardSubtitle}" Margin="0,4,0,16"/>
                                            
                                            <StackPanel x:Name="DiscoveredDevicesList">
                                                <TextBlock Text="Searching for devices..." 
                                                           Style="{StaticResource SettingDescription}" 
                                                           HorizontalAlignment="Center" Margin="0,10"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Stats Card -->
                                    <Border x:Name="PlayerStatsCard" Style="{StaticResource ModernCard}" Margin="0,16,0,0" Visibility="Collapsed">
                                        <Border.RenderTransform>
                                            <TranslateTransform x:Name="PlayerStatsCardTransform"/>
                                        </Border.RenderTransform>
                                        <StackPanel>
                                            <Grid Margin="0,0,0,20">
                                                <TextBlock Text="Live Statistics" Style="{StaticResource CardTitle}"/>
                                                <Button HorizontalAlignment="Right" Style="{StaticResource GhostButton}" Click="BtnStartMic_Click">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⏹" Foreground="#FF5252" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="STOP STREAMING" Foreground="#FF5252" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" MinWidth="160"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*" MinWidth="160"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Buffer -->
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <TextBlock Text="🎹" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="BUFFER" Style="{StaticResource StatLabel}"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="TxtBuffer" Text="0 ms"
                                                               Style="{StaticResource StatValue}" Margin="24,0,0,0"/>
                                                </StackPanel>

                                                <!-- Divider -->
                                                <Border Grid.Column="1" Width="1" Background="{StaticResource DividerBrush}"
                                                        Margin="16,0"/>

                                                <!-- Latency -->
                                                <StackPanel Grid.Column="2">
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                        <TextBlock Text="📡" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <TextBlock Text="LATENCY" Style="{StaticResource StatLabel}"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="24,0,0,0">
                                                        <TextBlock Text="Average" FontSize="11"
                                                            Foreground="{StaticResource TextSecBrush}"/>
                                                        <TextBlock x:Name="TxtLatency" Text="0.0 ms"
                                                            Style="{StaticResource StatValue}" FontSize="16"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                <!-- Warning / Status -->
                                <Border x:Name="PlayerStatusCard" Padding="20,14" CornerRadius="8" Margin="0,16,0,0">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="PlayerStatusBg" Color="{StaticResource WarningBgColor}"/>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="PlayerStatusIcon" Text="⚠" Margin="0,0,10,0" FontSize="14">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush x:Name="PlayerStatusIconColor" Color="{StaticResource WarningColor}"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock x:Name="TxtPlayerStatus" Text="Not connected"
                                                   Foreground="{StaticResource TextSecBrush}" FontSize="13"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Right Column (Mode Selection) -->
                            <StackPanel Grid.Column="2">
                                <Border Style="{StaticResource ModernCard}">
                                    <StackPanel>
                                        <TextBlock Text="Mode" Style="{StaticResource CardTitle}" Margin="0,0,0,20"/>
                                        <RadioButton IsChecked="True" Style="{StaticResource ModeRadioButton}"
                                                     GroupName="PlayerMode">
                                            <StackPanel>
                                                <TextBlock Text="Mic" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock Text="Use your phone's mic"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton Style="{StaticResource ModeRadioButton}"
                                                     GroupName="PlayerMode" Margin="0,14,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Playback" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock Text="Listen to another device"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                        </RadioButton>

                                        <TextBlock Text="Output Device" Style="{StaticResource SettingDescription}"
                                                   Margin="0,28,0,10"/>
                                        <Button x:Name="BtnSelectOutputDevice" Click="BtnSelectOutputDevice_Click"
                                                Cursor="Hand" Background="#2A2A2E" Foreground="White"
                                                BorderBrush="#444" BorderThickness="1"
                                                Padding="14,12" HorizontalContentAlignment="Stretch">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <Grid>
                                                            <TextBlock x:Name="TxtSelectedOutputDeviceName"
                                                                       Text="System default"
                                                                       Foreground="White" FontSize="13"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       VerticalAlignment="Center" Margin="0,0,30,0"/>
                                                            <Path Data="M0,0 L5,5 L0,10" 
                                                                  Stroke="{StaticResource AccentBrush}" 
                                                                  StrokeThickness="2" 
                                                                  Width="8" Height="12" 
                                                                  Stretch="Uniform" 
                                                                  HorizontalAlignment="Right" 
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,4,0" 
                                                                  StrokeStartLineCap="Round" 
                                                                  StrokeEndLineCap="Round" 
                                                                  StrokeLineJoin="Round"/>
                                                        </Grid>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <!-- ═══ Output Device Picker View (overlays on top) ═══ -->
                    <Grid x:Name="OutputDevicePickerView" Background="#1E1E1E" Visibility="Collapsed" Opacity="0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="OutputDevicePickerTransform" X="400"/>
                        </Grid.RenderTransform>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="48,36,48,24" HorizontalAlignment="Center" MaxWidth="520">
                                <!-- Back button + title -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <Button x:Name="BtnBackFromOutputDevices" Click="BtnBackFromOutputDevices_Click"
                                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                                            Foreground="#4CAF50" Padding="8,4" Margin="0,0,12,0"
                                            VerticalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Root" Background="{TemplateBinding Background}" 
                                                        Padding="{TemplateBinding Padding}" CornerRadius="6">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path x:Name="Arrow" Data="M8,16 L0,8 L8,0" Stroke="{TemplateBinding Foreground}" 
                                                              StrokeThickness="2.5" Width="10" Height="16" Stretch="Uniform" Margin="0,0,10,0" 
                                                              VerticalAlignment="Center" StrokeStartLineCap="Round" 
                                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                                        <TextBlock x:Name="Text" Text="BACK" FontSize="14" FontWeight="Bold" 
                                                                   Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#224CAF50"/>
                                                        <Setter Property="Foreground" Value="#66FF66"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Root" Property="Background" Value="#444CAF50"/>
                                                        <Setter Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <Border Style="{StaticResource ModernCard}" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="Select output device" Style="{StaticResource CardTitle}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Choose which audio device to play receiving audio"
                                                   Style="{StaticResource CardSubtitle}" Margin="0,0,0,16"/>
                                        <StackPanel x:Name="OutputDeviceList">
                                            <!-- Populated by code-behind -->
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

                <!-- ════════════════════════════════════════ -->
                <!-- TAB 3: SETTINGS                         -->
                <!-- ════════════════════════════════════════ -->
                <TabItem>
                    <ScrollViewer Margin="48,36,48,24" VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="540" HorizontalAlignment="Center">

                            <!-- DISPLAY SECTION -->
                            <TextBlock Text="Display" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource ModernCard}" Padding="0">
                                <StackPanel>
                                    <!-- Device Name -->
                                    <Border Padding="24,20" BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource DividerBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock Text="Device name" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock Text="The name displayed to other devices"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                            <TextBox x:Name="TxtDeviceName" Grid.Column="1" Text="DESKTOP-PC" HorizontalAlignment="Right" Width="180"
                                                     Style="{StaticResource ModernTextBox}" VerticalAlignment="Center"
                                                     TextChanged="SettingsChanged"/>
                                        </Grid>
                                    </Border>

                                    <!-- Dark Theme -->
                                    <Border Padding="24,20" BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource DividerBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Dark theme" Style="{StaticResource SettingLabel}"
                                                       VerticalAlignment="Center" Margin="0,0,20,0"/>
                                            <CheckBox x:Name="ChkDarkTheme" Grid.Column="1" IsChecked="True" Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right" Checked="SettingsChanged" Unchecked="SettingsChanged"/>
                                        </Grid>
                                    </Border>

                                    <!-- Minimize Window -->
                                    <Border Padding="24,20" BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource DividerBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock Text="Minimize to system tray" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock Text="Hide the window in the system tray when minimized"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ChkMinimizeToTray" Grid.Column="1" IsChecked="True" Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right" Checked="SettingsChanged" Unchecked="SettingsChanged"/>
                                        </Grid>
                                    </Border>

                                    <!-- Language -->
                                    <Border Padding="24,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock Text="Language" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock Text="Choose the display language"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                            <Button x:Name="BtnLanguage" Grid.Column="1" Content="English" HorizontalAlignment="Right"
                                                    Background="Transparent"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    BorderThickness="0" FontWeight="SemiBold"
                                                    FontSize="14" Cursor="Hand" Click="BtnLanguage_Click"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- STARTUP SECTION -->
                            <TextBlock Text="Startup" Style="{StaticResource SectionHeader}" Margin="0,36,0,20"/>
                            <Border Style="{StaticResource ModernCard}" Padding="0">
                                <Border Padding="24,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Launch AudioTransfer on computer startup"
                                                   Style="{StaticResource SettingLabel}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        <CheckBox x:Name="ChkStartup" Grid.Column="1" Style="{StaticResource ToggleSwitch}" HorizontalAlignment="Right"
                                                  Checked="ChkStartup_Checked" Unchecked="ChkStartup_Unchecked"/>
                                    </Grid>
                                </Border>
                            </Border>

                            <!-- AUDIO SECTION -->
                            <TextBlock Text="Audio" Style="{StaticResource SectionHeader}" Margin="0,36,0,20"/>
                            <Border Style="{StaticResource ModernCard}" Padding="0">
                                <StackPanel>
                                    <Border Padding="24,20" BorderThickness="0,0,0,1" BorderBrush="{StaticResource DividerBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock Text="Mute system audio when streaming"
                                                           Style="{StaticResource SettingLabel}"/>
                                                <TextBlock Text="Automatically mute the PC when audio is being sent"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ChkAutoMute" Grid.Column="1" Style="{StaticResource ToggleSwitch}" 
                                                      HorizontalAlignment="Right" Checked="SettingsChanged" Unchecked="SettingsChanged"/>
                                        </Grid>
                                    </Border>
                                    <Border Padding="24,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock Text="System logs" Style="{StaticResource SettingLabel}"/>
                                                <TextBlock Text="View application events and debug information"
                                                           Style="{StaticResource SettingDescription}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="OPEN LOGS" Click="BtnShowLogs_Click" 
                                                    HorizontalAlignment="Right" Background="Transparent"
                                                    Foreground="{StaticResource AccentBrush}"
                                                    BorderThickness="0" FontWeight="SemiBold"
                                                    FontSize="14" Cursor="Hand"/>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- BOTTOM NAVIGATION BAR                          -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource BottomBarBrush}"
                BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,4,0,4">
                <RadioButton IsChecked="True" Style="{StaticResource NavButtonStyle}"
                             Checked="Nav_Click" Name="NavServer">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🖥️" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="Server" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton Style="{StaticResource NavButtonStyle}"
                             Checked="Nav_Click" Name="NavPlayer">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🎵" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="Player" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton Style="{StaticResource NavButtonStyle}"
                             Checked="Nav_Click" Name="NavSettings">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                        <TextBlock Text="Settings" FontSize="12" HorizontalAlignment="Center"/>
                    </StackPanel>
                </RadioButton>
            </StackPanel>
        </Border>
    </Grid>

</Window>
