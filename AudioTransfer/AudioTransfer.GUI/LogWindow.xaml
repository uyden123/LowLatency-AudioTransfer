<Window x:Class="AudioTransfer.GUI.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Logs" Height="450" Width="800"
        Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    
    <Window.Resources>
        <Style x:Key="LogToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Toolbar -->
        <Grid Margin="0,0,0,12">
            <TextBlock Text="SYSTEM LOGS" FontWeight="SemiBold" VerticalAlignment="Center" 
                       Foreground="{DynamicResource AccentBrush}" FontSize="13"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="BtnClear_Click" Style="{StaticResource LogToolbarButton}" ToolTip="Clear Logs">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </Button>
                <Button x:Name="BtnPause" Click="BtnPause_Click" Style="{StaticResource LogToolbarButton}" ToolTip="Pause/Resume Updates">
                    <TextBlock x:Name="TxtPauseIcon" Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </Button>
                <Button Click="BtnRefresh_Click" Style="{StaticResource LogToolbarButton}" ToolTip="Reload from Memory">
                    <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </Button>
                <Button Click="BtnExport_Click" Style="{StaticResource LogToolbarButton}" ToolTip="Export to File">
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="16"/>
                </Button>
            </StackPanel>
        </Grid>
        
        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" CornerRadius="8" 
                BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1">
            <TextBox x:Name="TxtLogs" 
                     IsReadOnly="True" 
                     Background="Transparent" 
                     Foreground="{DynamicResource TextPrimaryBrush}" 
                     BorderThickness="0" 
                     VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     FontSize="12"
                     Padding="12"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="TxtStatus" Text="Monitoring active logs..." 
                       VerticalAlignment="Center" Foreground="{DynamicResource TextSecBrush}" FontSize="12"/>
            
            <Button Content="CLOSE" Click="BtnClose_Click" HorizontalAlignment="Right"
                    Width="100" Height="32" Padding="0,4" 
                    BorderBrush="{DynamicResource DividerBrush}" 
                    Background="{DynamicResource SurfaceBrush}" 
                    Foreground="{DynamicResource TextPrimaryBrush}">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>
