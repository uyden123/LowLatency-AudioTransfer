<Window x:Class="AudioTransfer.GUI.LogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Logs" Height="450" Width="800"
        Background="#121212" Foreground="#E0E0E0"
        WindowStartupLocation="CenterScreen"
        FontFamily="Consolas"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="AUDIO TRANSFER SYSTEM LOGS" FontWeight="Bold" Foreground="#4CAF50" FontSize="14" Margin="0,0,0,12"/>
        
        <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="4" BorderBrush="#333" BorderThickness="1">
            <TextBox x:Name="TxtLogs" 
                     IsReadOnly="True" 
                     Background="Transparent" 
                     Foreground="#CCC" 
                     BorderThickness="0" 
                     VerticalScrollBarVisibility="Auto" 
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="Wrap"
                     Padding="8"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="CLEAR" Click="BtnClear_Click" Width="80" Padding="0,4" Margin="0,0,8,0" Background="#2D2D2D" Foreground="White" BorderBrush="#444"/>
            <Button Content="CLOSE" Click="BtnClose_Click" Width="80" Padding="0,4" Background="#2D2D2D" Foreground="White" BorderBrush="#444"/>
        </StackPanel>
    </Grid>
</Window>
